        immediately and ``buffer`` is ``None``.

        Calls the getrange function of ``pad``, see :class:`GstPadGetRangeFunction` for a
        description of a getrange function. If ``pad`` has no getrange function
        installed (see gst_pad_set_getrange_function()) this function returns
        :data:`Gst.FlowReturn.NOT_SUPPORTED`.

        If ``buffer`` points to a variable holding ``None``, a valid new :class:`Gst.Buffer` will be
        placed in ``buffer`` when this function returns :data:`Gst.FlowReturn.OK`. The new buffer
        must be freed with gst_buffer_unref() after usage.

        When ``buffer`` points to a variable that points to a valid :class:`Gst.Buffer`, the
        buffer will be filled with the result data when this function returns
        :data:`Gst.FlowReturn.OK`. If the provided buffer is larger than ``size``, only
        ``size`` bytes will be filled in the result buffer and its size will be updated
        accordingly.

        Note that less than ``size`` bytes can be returned in ``buffer`` when, for example,
        an EOS condition is near or when ``buffer`` is not large enough to hold ``size``
        bytes. The caller should check the result buffer size to get the result size.

        When this function returns any other result value than :data:`Gst.FlowReturn.OK`, ``buffer``
        will be unchanged.

        This is a lowlevel function. Usually :meth:`Gst.Pad.pull_range` is used.
        """
    def get_single_internal_link(self) -> Pad | None:
        """
        If there is a single internal link of the given pad, this function will
        return it. Otherwise, it will return NULL.
        """
    def get_sticky_event(self, event_type: EventType | int, idx: int) -> Event | None:
        """
        Returns a new reference of the sticky event of type ``event_type``
        from the event.
        """
    def get_stream(self) -> Stream | None:
        """
        Returns the current :class:`Gst.Stream` for the ``pad``, or ``None`` if none has been
        set yet, i.e. the pad has not received a stream-start event yet.

        This is a convenience wrapper around :meth:`Gst.Pad.get_sticky_event` and
        :meth:`Gst.Event.parse_stream`.
        """
    def get_stream_id(self) -> str | None:
        """
        Returns the current stream-id for the ``pad``, or ``None`` if none has been
        set yet, i.e. the pad has not received a stream-start event yet.

        This is a convenience wrapper around :meth:`Gst.Pad.get_sticky_event` and
        :meth:`Gst.Event.parse_stream_start`.

        The returned stream-id string should be treated as an opaque string, its
        contents should not be interpreted.
        """
    def get_task_state(self) -> TaskState:
        """
        Get ``pad`` task state. If no task is currently
        set, :data:`Gst.TaskState.STOPPED` is returned.
        """
    def has_current_caps(self) -> bool:
        """
        Check if ``pad`` has caps set on it with a :data:`Gst.EventType.CAPS` event.
        """
    def is_active(self) -> bool:
        """
        Query if a pad is active
        """
    def is_blocked(self) -> bool:
        """
        Checks if the pad is blocked or not. This function returns the
        last requested state of the pad. It is not certain that the pad
        is actually blocking at this point (see :meth:`Gst.Pad.is_blocking`).
        """
    def is_blocking(self) -> bool:
        """
        Checks if the pad is blocking or not. This is a guaranteed state
        of whether the pad is actually blocking on a :class:`Gst.Buffer` or a :class:`Gst.Event`.
        """
    def is_linked(self) -> bool:
        """
        Checks if a ``pad`` is linked to another pad or not.
        """
    def iterate_internal_links(self) -> Iterator | None:
        """
        Gets an iterator for the pads to which the given pad is linked to inside
        of the parent element.

        Each :class:`Gst.Pad` element yielded by the iterator will have its refcount increased,
        so unref after use.

        Free-function: :meth:`Gst.Iterator.free`
        """
    def iterate_internal_links_default(self, parent: Object | None = ...) -> Iterator | None:
        """
        Iterate the list of pads to which the given pad is linked to inside of
        the parent element.
        This is the default handler, and thus returns an iterator of all of the
        pads inside the parent element with opposite direction.

        The caller must free this iterator after use with :meth:`Gst.Iterator.free`.
        """
    def link(self, sinkpad: Pad) -> PadLinkReturn:
        """
        Links the source pad and the sink pad.
        """
    def link_full(self, sinkpad: Pad, flags: PadLinkCheck | int) -> PadLinkReturn:
        """
        Links the source pad and the sink pad.

        This variant of #:meth:`Gst.Pad.link` provides a more granular control on the
        checks being done when linking. While providing some considerable speedups
        the caller of this method must be aware that wrong usage of those flags
        can cause severe issues. Refer to the documentation of :class:`Gst.PadLinkCheck`
        for more information.

        MT Safe.
        """
