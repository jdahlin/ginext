    .. code-block:: c

        static void
        on_response (:class:`Gtk.NativeDialog` *native,
                     int              response)
        {
          if (response == GTK_RESPONSE_ACCEPT)
            {
              :class:`Gtk.FileChooser` *chooser = GTK_FILE_CHOOSER (native);
              GFile *file = :meth:`Gtk.FileChooser.get_file` (chooser);

              save_to_file (file);

              g_object_unref (file);
            }

          g_object_unref (native);
        }

          // ...
          :class:`Gtk.FileChooserNative` *native;
          :class:`Gtk.FileChooser` *chooser;
          :class:`Gtk.FileChooserAction` action = GTK_FILE_CHOOSER_ACTION_SAVE;

          native = :meth:`Gtk.FileChooserNative.new` ("Save File",
                                                parent_window,
                                                action,
                                                "_Save",
                                                "_Cancel");
          chooser = GTK_FILE_CHOOSER (native);

          if (user_edited_a_new_document)
            :meth:`Gtk.FileChooser.set_current_name` (chooser, _("Untitled document"));
          else
            :meth:`Gtk.FileChooser.set_file` (chooser, existing_file, NULL);

