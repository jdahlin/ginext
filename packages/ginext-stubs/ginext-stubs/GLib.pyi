    URIs usefully requires scheme-specific knowledge that :class:`GLib.Uri` does
    not have. :class:`GLib.Uri` can help with normalization if you use the various
    encoded :class:`GLib.UriFlags` as well as ``G_URI_FLAGS_SCHEME_NORMALIZE``
    however it is not comprehensive.
    For example, ``data:,foo`` and ``data:;base64,Zm9v`` resolve to the same
    thing according to the ``data:`` URI specification which GLib does not
    handle.
    """
    gimeta: ClassVar[_GIMeta]
    def get_auth_params(self) -> str | None:
