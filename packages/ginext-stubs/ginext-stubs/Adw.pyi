        If :meth:`NavigationView.add` hasn't been called, the page is automatically
        removed once it's popped.

        ``NavigationView::pushed`` will be emitted for ``page``.

        See :meth:`NavigationView.push_by_tag`.
        """
    def push_by_tag(self, tag: str) -> None:
