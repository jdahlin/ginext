class PopoverMenuBar(Widget, Accessible, Buildable, ConstraintTarget):
    """
    Presents a horizontal bar of items that pop up menus when clicked.

    <picture>
      <source srcset="menubar-dark.png" media="(prefers-color-scheme: dark)">
      <img alt="An example :class:`Gtk.PopoverMenuBar`" src="menubar.png">
