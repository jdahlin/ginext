@deprecated("Deprecated since 2.26.")
class Relation:
    """
    A :class:`GLib.Relation` is a table of data which can be indexed on any number
    of fields, rather like simple database tables. A :class:`GLib.Relation` contains
    a number of records, called tuples. Each record contains a number of
    fields. Records are not ordered, so it is not possible to find the
    record at a particular index.

    Note that :class:`GLib.Relation` tables are currently limited to 2 fields.

    To create a :class:`GLib.Relation`, use :func:`GLib.Relation.new`.

    To specify which fields should be indexed, use :meth:`GLib.Relation.index`.
    Note that this must be called before any tuples are added to the
    :class:`GLib.Relation`.

    To add records to a :class:`GLib.Relation` use :meth:`GLib.Relation.insert`.

    To determine if a given record appears in a :class:`GLib.Relation`, use
    :meth:`GLib.Relation.exists`. Note that fields are compared directly, so
    pointers must point to the exact same position (i.e. different
    copies of the same string will not match.)

    To count the number of records which have a particular value in a
    given field, use :meth:`GLib.Relation.count`.

    To get all the records which have a particular value in a given
    field, use :meth:`GLib.Relation.select`. To access fields of the resulting
    records, use :meth:`GLib.Tuples.index`. To free the resulting records use
    :meth:`GLib.Tuples.destroy`.

    To delete all records which have a particular value in a given
    field, use :meth:`GLib.Relation.delete`.

    To destroy the :class:`GLib.Relation`, use :meth:`GLib.Relation.destroy`.

    To help debug :class:`GLib.Relation` objects, use :meth:`GLib.Relation.print`.

    :class:`GLib.Relation` has been marked as deprecated, since this API has never
    been fully implemented, is not very actively maintained and rarely
    used.
    """
    gimeta: ClassVar[_GIMeta]
    @deprecated("Deprecated since 2.26.")
    def count(self, key: int | None, field: int) -> int:
        """
        Returns the number of tuples in a :class:`GLib.Relation` that have the given
        value in the given field.
        """
    @deprecated("Deprecated since 2.26.")
    def delete(self, key: int | None, field: int) -> int:
        """
        Deletes any records from a :class:`GLib.Relation` that have the given key value
        in the given field.
        """
    @deprecated("Deprecated since 2.26.")
    def destroy(self) -> None:
        """
        Destroys the :class:`GLib.Relation`, freeing all memory allocated. However, it
        does not free memory allocated for the tuple data, so you should
        free that first if appropriate.
        """
    @deprecated("Deprecated since 2.26.")
    def print(self) -> None:
        """
        Outputs information about all records in a :class:`GLib.Relation`, as well as
        the indexes. It is for debugging.
        """

