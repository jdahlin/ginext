            <object class=":class:`Adw.HeaderBar`"/>
          </child>
          <property name="content">
            <object class=":class:`Adw.PreferencesPage`">
              <!-- ... -->
            </object>
          </property>
        </object>

    The following kinds of top and bottom bars are supported:

    - :class:`HeaderBar`
    - :class:`TabBar`
    - :class:`ViewSwitcherBar`
    - :class:`Gtk.ActionBar`
    - :class:`Gtk.HeaderBar`
    - :class:`Gtk.PopoverMenuBar`
    - :class:`Gtk.SearchBar`
