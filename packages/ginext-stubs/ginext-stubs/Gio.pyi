    def get() -> AppInfoMonitor:
        """
        Gets the :class:`Gio.AppInfoMonitor` for the current thread-default main
        context.

        The :class:`Gio.AppInfoMonitor` will emit a ŌĆ£changedŌĆØ signal in the
        thread-default main context whenever the list of installed
        applications (as reported by :func:`Gio.app_info_get_all`) may have changed.

        The :class:`Gio.AppInfoMonitor`::changed signal will only be emitted once until
        :func:`Gio.app_info_get_all` (or another ``g_app_info_*()`` function) is called. Doing
        so will re-arm the signal ready to notify about the next change.

