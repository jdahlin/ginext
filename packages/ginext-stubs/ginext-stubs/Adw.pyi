        ``page`` must be in the navigation stack.

        If :meth:`NavigationView.add` hasn't been called for any of the popped pages,
        they are automatically removed.

        ``NavigationView::popped`` will be be emitted for each of the popped
        pages.

        See :meth:`NavigationView.pop` and :meth:`NavigationView.pop_to_tag`.
        """
    def pop_to_tag(self, tag: str) -> bool:
