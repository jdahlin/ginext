class Task(GObject.Object, AsyncResult):
    """
    A :class:`Gio.Task` represents and manages a cancellable ŌĆśtaskŌĆÖ.

    ## Asynchronous operations

    The most common usage of :class:`Gio.Task` is as a :class:`Gio.AsyncResult`, to
    manage data during an asynchronous operation. You call
    :meth:`Gio.Task.new` in the ŌĆśstartŌĆÖ method, followed by
    :meth:`Gio.Task.set_task_data` and the like if you need to keep some
    additional data associated with the task, and then pass the
    task object around through your asynchronous operation.
    Eventually, you will call a method such as
    :meth:`Gio.Task.return_pointer` or :meth:`Gio.Task.return_error`, which
    will save the value you give it and then invoke the taskŌĆÖs callback
    function in the thread-default main context (see
    :meth:`GLib.MainContext.push_thread_default`)
    where it was created (waiting until the next iteration of the main
    loop first, if necessary). The caller will pass the :class:`Gio.Task` back to
    the operationŌĆÖs finish function (as a :class:`Gio.AsyncResult`), and you can
    use :meth:`Gio.Task.propagate_pointer` or the like to extract the
    return value.

    Using :class:`Gio.Task` requires the thread-default :class:`GLib.MainContext` from when
    the :class:`Gio.Task` was constructed to be running at least until the task has
    completed and its data has been freed.

    If a :class:`Gio.Task` has been constructed and its callback set, it is an error to
    not call ``g_task_return_*()`` on it. GLib will warn at runtime if this happens
    (since 2.76).

    Here is an example for using :class:`Gio.Task` as a :class:`Gio.AsyncResult`:
    .. code-block:: c

        typedef struct {
          CakeFrostingType frosting;
          char *message;
        } DecorationData;

        static void
        decoration_data_free (DecorationData *decoration)
        {
          g_free (decoration->message);
          g_slice_free (DecorationData, decoration);
        }

        static void
        baked_cb (Cake     *cake,
                  gpointer  user_data)
        {
          :class:`Gio.Task` *task = user_data;
          DecorationData *decoration = :meth:`Gio.Task.get_task_data` (task);
          GError *error = NULL;

          if (cake == NULL)
            {
              g_task_return_new_error (task, BAKER_ERROR, BAKER_ERROR_NO_FLOUR,
                                       "Go to the supermarket");
              g_object_unref (task);
              return;
            }

          if (!cake_decorate (cake, decoration->frosting, decoration->message, &error))
            {
              g_object_unref (cake);
              // :meth:`Gio.Task.return_error` takes ownership of error
              :meth:`Gio.Task.return_error` (task, error);
              g_object_unref (task);
              return;
            }

          :meth:`Gio.Task.return_pointer` (task, cake, g_object_unref);
          g_object_unref (task);
        }

        void
        baker_bake_cake_async (Baker               *self,
                               guint                radius,
                               CakeFlavor           flavor,
                               CakeFrostingType     frosting,
                               const char          *message,
                               :class:`Gio.Cancellable`        *cancellable,
                               GAsyncReadyCallback  callback,
                               gpointer             user_data)
        {
          :class:`Gio.Task` *task;
          DecorationData *decoration;
          Cake  *cake;

          task = :meth:`Gio.Task.new` (self, cancellable, callback, user_data);
          if (radius < 3)
            {
              g_task_return_new_error (task, BAKER_ERROR, BAKER_ERROR_TOO_SMALL,
                                       "``ucm`` radius cakes are silly",
                                       radius);
              g_object_unref (task);
              return;
            }

          cake = _baker_get_cached_cake (self, radius, flavor, frosting, message);
          if (cake != NULL)
            {
              // _baker_get_cached_cake() returns a reffed cake
              :meth:`Gio.Task.return_pointer` (task, cake, g_object_unref);
              g_object_unref (task);
              return;
            }

          decoration = g_slice_new (DecorationData);
          decoration->frosting = frosting;
          decoration->message = g_strdup (message);
          :meth:`Gio.Task.set_task_data` (task, decoration, (GDestroyNotify) decoration_data_free);

          _baker_begin_cake (self, radius, flavor, cancellable, baked_cb, task);
        }

        Cake *
        baker_bake_cake_finish (Baker         *self,
                                :class:`Gio.AsyncResult`  *result,
                                GError       **error)
        {
          g_return_val_if_fail (:meth:`Gio.Task.is_valid` (result, self), NULL);

          return :meth:`Gio.Task.propagate_pointer` (G_TASK (result), error);
        }

    ## Chained asynchronous operations

    :class:`Gio.Task` also tries to simplify asynchronous operations that
    internally chain together several smaller asynchronous
    operations. :meth:`Gio.Task.get_cancellable`, :meth:`Gio.Task.get_context`,
    and :meth:`Gio.Task.get_priority` allow you to get back the taskŌĆÖs
    :class:`Gio.Cancellable`, :class:`GLib.MainContext`, and
    [I/O priority](iface.AsyncResult.html#io-priority)
    when starting a new subtask, so you donŌĆÖt have to keep track
    of them yourself. :meth:`Gio.Task.attach_source` simplifies the case
    of waiting for a source to fire (automatically using the correct
    :class:`GLib.MainContext` and priority).

    Here is an example for chained asynchronous operations:
    .. code-block:: c

        typedef struct {
          Cake *cake;
          CakeFrostingType frosting;
          char *message;
        } BakingData;

        static void
        decoration_data_free (BakingData *bd)
        {
          if (bd->cake)
            g_object_unref (bd->cake);
          g_free (bd->message);
          g_slice_free (BakingData, bd);
        }

        static void
        decorated_cb (Cake         *cake,
                      :class:`Gio.AsyncResult` *result,
                      gpointer      user_data)
        {
          :class:`Gio.Task` *task = user_data;
          GError *error = NULL;

          if (!cake_decorate_finish (cake, result, &error))
            {
              g_object_unref (cake);
              :meth:`Gio.Task.return_error` (task, error);
              g_object_unref (task);
              return;
            }

          // baking_data_free() will drop its ref on the cake, so we have to
          // take another here to give to the caller.
          :meth:`Gio.Task.return_pointer` (task, g_object_ref (cake), g_object_unref);
          g_object_unref (task);
        }

        static gboolean
        decorator_ready (gpointer user_data)
        {
          :class:`Gio.Task` *task = user_data;
          BakingData *bd = :meth:`Gio.Task.get_task_data` (task);

          cake_decorate_async (bd->cake, bd->frosting, bd->message,
                               :meth:`Gio.Task.get_cancellable` (task),
                               decorated_cb, task);

          return G_SOURCE_REMOVE;
        }

        static void
        baked_cb (Cake     *cake,
                  gpointer  user_data)
        {
          :class:`Gio.Task` *task = user_data;
          BakingData *bd = :meth:`Gio.Task.get_task_data` (task);
          GError *error = NULL;

          if (cake == NULL)
            {
              g_task_return_new_error (task, BAKER_ERROR, BAKER_ERROR_NO_FLOUR,
                                       "Go to the supermarket");
              g_object_unref (task);
              return;
            }

          bd->cake = cake;

          // Bail out now if the user has already cancelled
          if (:meth:`Gio.Task.return_error_if_cancelled` (task))
            {
              g_object_unref (task);
              return;
            }

          if (cake_decorator_available (cake))
            decorator_ready (task);
          else
            {
              GSource *source;

              source = cake_decorator_wait_source_new (cake);
              // Attach ``source`` to ``task``ŌĆÖs GMainContext and have it call
              // decorator_ready() when it is ready.
              g_task_attach_source (task, source, decorator_ready);
              g_source_unref (source);
            }
        }

        void
        baker_bake_cake_async (Baker               *self,
                               guint                radius,
                               CakeFlavor           flavor,
                               CakeFrostingType     frosting,
                               const char          *message,
                               gint                 priority,
                               :class:`Gio.Cancellable`        *cancellable,
                               GAsyncReadyCallback  callback,
                               gpointer             user_data)
        {
          :class:`Gio.Task` *task;
          BakingData *bd;

          task = :meth:`Gio.Task.new` (self, cancellable, callback, user_data);
          :meth:`Gio.Task.set_priority` (task, priority);

          bd = g_slice_new0 (BakingData);
          bd->frosting = frosting;
          bd->message = g_strdup (message);
          :meth:`Gio.Task.set_task_data` (task, bd, (GDestroyNotify) baking_data_free);

          _baker_begin_cake (self, radius, flavor, cancellable, baked_cb, task);
        }

        Cake *
        baker_bake_cake_finish (Baker         *self,
                                :class:`Gio.AsyncResult`  *result,
                                GError       **error)
        {
          g_return_val_if_fail (:meth:`Gio.Task.is_valid` (result, self), NULL);

          return :meth:`Gio.Task.propagate_pointer` (G_TASK (result), error);
        }

    ## Asynchronous operations from synchronous ones

    You can use :meth:`Gio.Task.run_in_thread` to turn a synchronous
    operation into an asynchronous one, by running it in a thread.
    When it completes, the result will be dispatched to the thread-default
    main context (see :meth:`GLib.MainContext.push_thread_default`)
    where the :class:`Gio.Task` was created.

    Running a task in a thread:
    .. code-block:: c

        typedef struct {
          guint radius;
          CakeFlavor flavor;
          CakeFrostingType frosting;
          char *message;
        } CakeData;

        static void
        cake_data_free (CakeData *cake_data)
        {
          g_free (cake_data->message);
          g_slice_free (CakeData, cake_data);
        }

        static void
        bake_cake_thread (:class:`Gio.Task`         *task,
                          gpointer       source_object,
                          gpointer       task_data,
                          :class:`Gio.Cancellable`  *cancellable)
        {
          Baker *self = source_object;
          CakeData *cake_data = task_data;
          Cake *cake;
          GError *error = NULL;

          cake = bake_cake (baker, cake_data->radius, cake_data->flavor,
                            cake_data->frosting, cake_data->message,
                            cancellable, &error);
          if (cake)
            :meth:`Gio.Task.return_pointer` (task, cake, g_object_unref);
          else
            :meth:`Gio.Task.return_error` (task, error);
        }

        void
        baker_bake_cake_async (Baker               *self,
                               guint                radius,
                               CakeFlavor           flavor,
                               CakeFrostingType     frosting,
                               const char          *message,
                               :class:`Gio.Cancellable`        *cancellable,
                               GAsyncReadyCallback  callback,
                               gpointer             user_data)
        {
          CakeData *cake_data;
          :class:`Gio.Task` *task;

          cake_data = g_slice_new (CakeData);
          cake_data->radius = radius;
          cake_data->flavor = flavor;
          cake_data->frosting = frosting;
          cake_data->message = g_strdup (message);
          task = :meth:`Gio.Task.new` (self, cancellable, callback, user_data);
          :meth:`Gio.Task.set_task_data` (task, cake_data, (GDestroyNotify) cake_data_free);
          :meth:`Gio.Task.run_in_thread` (task, bake_cake_thread);
          g_object_unref (task);
        }

        Cake *
        baker_bake_cake_finish (Baker         *self,
                                :class:`Gio.AsyncResult`  *result,
                                GError       **error)
        {
          g_return_val_if_fail (:meth:`Gio.Task.is_valid` (result, self), NULL);

          return :meth:`Gio.Task.propagate_pointer` (G_TASK (result), error);
        }

    ## Adding cancellability to uncancellable tasks

    Finally, :meth:`Gio.Task.run_in_thread` and
    :meth:`Gio.Task.run_in_thread_sync` can be used to turn an uncancellable
    operation into a cancellable one. If you call
    :meth:`Gio.Task.set_return_on_cancel`, passing ``True``, then if the taskŌĆÖs
    :class:`Gio.Cancellable` is cancelled, it will return control back to the
    caller immediately, while allowing the task thread to continue running in the
    background (and simply discarding its result when it finally does finish).
    Provided that the task thread is careful about how it uses
    locks and other externally-visible resources, this allows you
    to make ŌĆśGLib-friendlyŌĆÖ asynchronous and cancellable
    synchronous variants of blocking APIs.

    Cancelling a task:
    .. code-block:: c

        static void
        bake_cake_thread (:class:`Gio.Task`         *task,
                          gpointer       source_object,
                          gpointer       task_data,
                          :class:`Gio.Cancellable`  *cancellable)
        {
          Baker *self = source_object;
          CakeData *cake_data = task_data;
          Cake *cake;
          GError *error = NULL;

          cake = bake_cake (baker, cake_data->radius, cake_data->flavor,
                            cake_data->frosting, cake_data->message,
                            &error);
          if (error)
            {
              :meth:`Gio.Task.return_error` (task, error);
              return;
            }

          // If the task has already been cancelled, then we donŌĆÖt want to add
          // the cake to the cake cache. Likewise, we donŌĆÖt  want to have the
          // task get cancelled in the middle of updating the cache.
          // :meth:`Gio.Task.set_return_on_cancel` will return ``True`` here if it managed
          // to disable return-on-cancel, or ``False`` if the task was cancelled
          // before it could.
          if (:meth:`Gio.Task.set_return_on_cancel` (task, FALSE))
            {
              // If the caller cancels at this point, their
              // GAsyncReadyCallback wonŌĆÖt be invoked until we return,
              // so we donŌĆÖt have to worry that this code will run at
              // the same time as that code does. But if there were
              // other functions that might look at the cake cache,
              // then weŌĆÖd probably need a GMutex here as well.
              baker_add_cake_to_cache (baker, cake);
              :meth:`Gio.Task.return_pointer` (task, cake, g_object_unref);
            }
        }

        void
        baker_bake_cake_async (Baker               *self,
                               guint                radius,
                               CakeFlavor           flavor,
                               CakeFrostingType     frosting,
                               const char          *message,
                               :class:`Gio.Cancellable`        *cancellable,
                               GAsyncReadyCallback  callback,
                               gpointer             user_data)
        {
          CakeData *cake_data;
          :class:`Gio.Task` *task;

          cake_data = g_slice_new (CakeData);

          ...

          task = :meth:`Gio.Task.new` (self, cancellable, callback, user_data);
          :meth:`Gio.Task.set_task_data` (task, cake_data, (GDestroyNotify) cake_data_free);
          :meth:`Gio.Task.set_return_on_cancel` (task, TRUE);
          :meth:`Gio.Task.run_in_thread` (task, bake_cake_thread);
        }

        Cake *
        baker_bake_cake_sync (Baker               *self,
                              guint                radius,
                              CakeFlavor           flavor,
                              CakeFrostingType     frosting,
                              const char          *message,
                              :class:`Gio.Cancellable`        *cancellable,
                              GError             **error)
        {
          CakeData *cake_data;
          :class:`Gio.Task` *task;
          Cake *cake;

          cake_data = g_slice_new (CakeData);

          ...

          task = :meth:`Gio.Task.new` (self, cancellable, NULL, NULL);
          :meth:`Gio.Task.set_task_data` (task, cake_data, (GDestroyNotify) cake_data_free);
          :meth:`Gio.Task.set_return_on_cancel` (task, TRUE);
          :meth:`Gio.Task.run_in_thread_sync` (task, bake_cake_thread);

          cake = :meth:`Gio.Task.propagate_pointer` (task, error);
          g_object_unref (task);
          return cake;
        }

    ## Porting from :class:`Gio.SimpleAsyncResult`

    :class:`Gio.Task`ŌĆÖs API attempts to be simpler than :class:`Gio.SimpleAsyncResult`ŌĆÖs
    in several ways:

    - You can save task-specific data with :meth:`Gio.Task.set_task_data`, and
      retrieve it later with :meth:`Gio.Task.get_task_data`. This replaces the
      abuse of :meth:`Gio.SimpleAsyncResult.set_op_res_gpointer` for the same
      purpose with :class:`Gio.SimpleAsyncResult`.
    - In addition to the task data, :class:`Gio.Task` also keeps track of the
      [priority](iface.AsyncResult.html#io-priority), :class:`Gio.Cancellable`,
      and :class:`GLib.MainContext` associated with the task, so tasks that
      consist of a chain of simpler asynchronous operations will have easy access
      to those values when starting each sub-task.
    - :meth:`Gio.Task.return_error_if_cancelled` provides simplified
      handling for cancellation. In addition, cancellation
      overrides any other :class:`Gio.Task` return value by default, like
      :class:`Gio.SimpleAsyncResult` does when
      :meth:`Gio.SimpleAsyncResult.set_check_cancellable` is called.
      (You can use :meth:`Gio.Task.set_check_cancellable` to turn off that
      behavior.) On the other hand, :meth:`Gio.Task.run_in_thread`
      guarantees that it will always run your
      ``task_func``, even if the taskŌĆÖs :class:`Gio.Cancellable`
      is already cancelled before the task gets a chance to run;
      you can start your ``task_func`` with a
      :meth:`Gio.Task.return_error_if_cancelled` check if you need the
      old behavior.
    - The ŌĆśreturnŌĆÖ methods (eg, :meth:`Gio.Task.return_pointer`)
      automatically cause the task to be ŌĆścompletedŌĆÖ as well, and
      there is no need to worry about the ŌĆścompleteŌĆÖ vs ŌĆścomplete in idleŌĆÖ
      distinction. (:class:`Gio.Task` automatically figures out
      whether the taskŌĆÖs callback can be invoked directly, or
      if it needs to be sent to another :class:`GLib.MainContext`, or delayed
      until the next iteration of the current :class:`GLib.MainContext`.)
    - The ŌĆśfinishŌĆÖ functions for :class:`Gio.Task` based operations are generally
      much simpler than :class:`Gio.SimpleAsyncResult` ones, normally consisting
      of only a single call to :meth:`Gio.Task.propagate_pointer` or the like.
      Since :meth:`Gio.Task.propagate_pointer` ŌĆśstealsŌĆÖ the return value from
      the :class:`Gio.Task`, it is not necessary to juggle pointers around to
      prevent it from being freed twice.
    - With :class:`Gio.SimpleAsyncResult`, it was common to call
      :meth:`Gio.SimpleAsyncResult.propagate_error` from the
      ``_finish()`` wrapper function, and have
      virtual method implementations only deal with successful
      returns. This behavior is deprecated, because it makes it
      difficult for a subclass to chain to a parent classŌĆÖs async
      methods. Instead, the wrapper function should just be a
      simple wrapper, and the virtual method should call an
      appropriate ``g_task_propagate_`` function.
      Note that wrapper methods can now use
      :meth:`Gio.AsyncResult.legacy_propagate_error` to do old-style
      :class:`Gio.SimpleAsyncResult` error-returning behavior, and
      :meth:`Gio.AsyncResult.is_tagged` to check if a result is tagged as
      having come from the ``_async()`` wrapper
      function (for ŌĆśshort-circuitŌĆÖ results, such as when passing
      ``0`` to :meth:`Gio.InputStream.read_async`).

    ## Thread-safety considerations

    Due to some infelicities in the API design, there is a
    thread-safety concern that users of :class:`Gio.Task` have to be aware of:

    If the ``main`` thread drops its last reference to the source object
    or the task data before the task is finalized, then the finalizers
    of these objects may be called on the worker thread.

    This is a problem if the finalizers use non-threadsafe API, and
    can lead to hard-to-debug crashes. Possible workarounds include:

    - Clear task data in a signal handler for ``notify::completed``
    - Keep iterating a main context in the main thread and defer
      dropping the reference to the source object to that main
      context when the task is finalized
    """
    @staticmethod
    def new(source_object: Any, cancellable: Any, callback: Any, callback_data: Any = ...) -> Any:
        """
        Creates a :class:`Gio.Task` acting on ``source_object``, which will eventually be
        used to invoke ``callback`` in the current thread-default main context
        (see :meth:`GLib.MainContext.push_thread_default`).

        Call this in the "start" method of your asynchronous method, and
        pass the :class:`Gio.Task` around throughout the asynchronous operation. You
        can use :meth:`Gio.Task.set_task_data` to attach task-specific data to the
        object, which you can retrieve later via :meth:`Gio.Task.get_task_data`.

        By default, if ``cancellable`` is cancelled, then the return value of
        the task will always be :data:`Gio.IOErrorEnum.CANCELLED`, even if the task had
        already completed before the cancellation. This allows for
        simplified handling in cases where cancellation may imply that
        other objects that the task depends on have been destroyed. If you
        do not want this behavior, you can use
        :meth:`Gio.Task.set_check_cancellable` to change it.
        """
