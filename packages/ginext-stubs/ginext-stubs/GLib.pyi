    |[<!-- language="C" -->
      :class:`GLib.RWLock` lock;
      :class:`GLib.PtrArray` *array;

      gpointer
      my_array_get (guint index)
      {
        gpointer retval = NULL;

        if (!array)
          return NULL;

        :meth:`GLib.RWLock.reader_lock` (&lock);
        if (index < array->len)
          retval = g_ptr_array_index (array, index);
        :meth:`GLib.RWLock.reader_unlock` (&lock);

        return retval;
      }

      void
      my_array_set (guint index, gpointer data)
      {
        :meth:`GLib.RWLock.writer_lock` (&lock);

        if (!array)
          array = g_ptr_array_new ();

        if (index >= array->len)
          g_ptr_array_set_size (array, index+1);
        g_ptr_array_index (array, index) = data;

        :meth:`GLib.RWLock.writer_unlock` (&lock);
