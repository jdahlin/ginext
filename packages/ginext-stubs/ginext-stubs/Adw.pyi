    def do_unapply(self) -> None: ...

class BreakpointBin(Gtk.Widget, Gtk.Accessible, Gtk.Buildable, Gtk.ConstraintTarget):
    """
    A widget that changes layout based on available size.

    <picture>
      <source srcset="breakpoint-bin-dark.png" media="(prefers-color-scheme: dark)">
      <img src="breakpoint-bin.png" alt="breakpoint-bin">
    </picture>

    :class:`Adw.BreakpointBin` provides a way to use breakpoints without :class:`Window`,
    :class:`ApplicationWindow` or :class:`Dialog`. It can be useful for limiting
    breakpoints to a single page and similar purposes. Most applications
    shouldn't need it.

    :class:`Adw.BreakpointBin` is similar to :class:`Bin`. It has one child, set via the
    :attr:`BreakpointBin.child` property.

    When :class:`Adw.BreakpointBin` is resized, its child widget can rearrange its layout
    at specific thresholds.

    The thresholds and layout changes are defined via :class:`Breakpoint` objects.
    They can be added using :meth:`BreakpointBin.add_breakpoint`.

    Each breakpoint has a condition, specifying the bin's size and/or aspect
    ratio, and setters that automatically set object properties when that
    happens. The ``Breakpoint::apply`` and ``Breakpoint::unapply`` can
    be used instead for more complex scenarios.

    Breakpoints are only allowed to modify widgets inside the :class:`Adw.BreakpointBin`,
    but not on the :class:`Adw.BreakpointBin` itself or any other widgets.

    If multiple breakpoints can be used for the current size, the last one is
    always picked. The current breakpoint can be tracked using the
    :attr:`BreakpointBin.current-breakpoint` property.

    If none of the breakpoints can be used, that property will be set to ``None``,
    and the original property values will be used instead.

    ## Minimum Size

    Adding a breakpoint to :class:`Adw.BreakpointBin` will result in it having no minimum
    size. The :attr:`Gtk.Widget.width-request` and
    :attr:`Gtk.Widget.height-request` properties must always be set when using
    breakpoints, indicating the smallest size you want to support.

    The minimum size and breakpoint conditions must be carefully selected so that
    the child widget completely fits. If it doesn't, it will overflow and a
    warning message will be printed.

    When choosing minimum size, consider translations and text scale factor
    changes. Make sure to leave enough space for text labels, and enable
    ellipsizing or wrapping if they might not fit.

    For :class:`Gtk.Label` this can be done via :attr:`Gtk.Label.ellipsize`, or
    via :attr:`Gtk.Label.wrap` together with :attr:`Gtk.Label.wrap-mode`.

    For buttons, use :attr:`Gtk.Button.can-shrink`,
    :attr:`Gtk.MenuButton.can-shrink`, :attr:`Adw.SplitButton.can-shrink`,
    or :attr:`Adw.ButtonContent.can-shrink`.

    ## Example

    .. code-block:: c

        GtkWidget *bin, *child;
        :class:`Adw.Breakpoint` *breakpoint;

        bin = :meth:`Adw.BreakpointBin.new`;
        gtk_widget_set_size_request (bin, 150, 150);

        child = gtk_label_new ("Wide");
        gtk_label_set_ellipsize (GTK_LABEL (label), PANGO_ELLIPSIZE_END);
        gtk_widget_add_css_class (child, "title-1");
        :meth:`Adw.BreakpointBin.set_child` (ADW_BREAKPOINT_BIN (bin), child);

        breakpoint = :meth:`Adw.Breakpoint.new` (:func:`Adw.breakpoint_condition_parse` ("max-width: 200px"));
        adw_breakpoint_add_setters (breakpoint,
                                    G_OBJECT (child), "label", "Narrow",
                                    NULL);
        :meth:`Adw.BreakpointBin.add_breakpoint` (ADW_BREAKPOINT_BIN (bin), breakpoint);

    The bin has a single label inside it, displaying "Wide". When the bin's width
    is smaller than or equal to 200px, it changes to "Narrow".

    ## :class:`Adw.BreakpointBin` as ``GtkBuildable``

    :class:`Adw.BreakpointBin` allows adding :class:`Adw.Breakpoint` objects as children.

    Example of an :class:`Adw.BreakpointBin` UI definition:

    .. code-block:: xml

        <object class=":class:`Adw.BreakpointBin`">
          <property name="width-request">150</property>
          <property name="height-request">150</property>
          <property name="child">
            <object class="GtkLabel" id="child">
              <property name="label">Wide</property>
              <property name="ellipsize">end</property>
              <style>
                <class name="title-1"/>
              </style>
            </object>
          </property>
          <child>
            <object class=":class:`Adw.Breakpoint`">
              <condition>max-width: 200px</condition>
              <setter object="child" property="label">Narrow</setter>
            </object>
          </child>
        </object>

    See :class:`Breakpoint` documentation for details.
    """
    gimeta: ClassVar[_GIMeta]
    child: Gtk.Widget
    current_breakpoint: Breakpoint
    def __init__(self, *, child: Gtk.Widget = ..., **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    def add_breakpoint(self, breakpoint: Breakpoint) -> None:
        """
        Adds ``breakpoint`` to ``self``.
        """
    def get_child(self) -> Gtk.Widget | None:
        """
        Gets the child widget of ``self``.
        """
    def get_current_breakpoint(self) -> Breakpoint | None:
        """
        Gets the current breakpoint.
        """
    def remove_breakpoint(self, breakpoint: Breakpoint) -> None:
        """
        Removes ``breakpoint`` from ``self``.
        """
    def set_child(self, child: Gtk.Widget | None = ...) -> None:
        """
        Sets the child widget of ``self``.
        """

