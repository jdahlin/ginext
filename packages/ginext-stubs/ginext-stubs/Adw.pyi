class SidebarItem(GObject.Object):
    """
    An item within :class:`SidebarSection`.

    Sidebar items must have a title, set via :attr:`SidebarItem.title`.

    Sidebar items should, but are not required to, have an icon. Icons can be set
    from an icon name, via :attr:`SidebarItem.icon-name`, or a
    :class:`Gdk.Paintable`, via :attr:`SidebarItem.icon-paintable`.

    Items can also have subtitles, set with the :attr:`SidebarItem.subtitle`
    property. Subtitles should be used sparingly.

    To add a tooltip, use :attr:`SidebarItem.tooltip`. Tooltips always use
    Pango markup.

