class TabView(Gtk.Widget, Gtk.Accessible, Gtk.Buildable, Gtk.ConstraintTarget):
    """
    A dynamic tabbed container.

    :class:`Adw.TabView` is a container which shows one child at a time. While it
    provides keyboard shortcuts for switching between pages, it does not provide
    a visible tab switcher and relies on external widgets for that, such as
    :class:`TabBar`, :class:`TabOverview` and :class:`TabButton`.

    :class:`Adw.TabView` maintains a :class:`TabPage` object for each page, which holds
    additional per-page properties. You can obtain the :class:`Adw.TabPage` for a page
    with :meth:`TabView.get_page`, and as the return value for
    :meth:`TabView.append` and other functions for adding children.

    :class:`Adw.TabView` only aims to be useful for dynamic tabs in multi-window
    document-based applications, such as web browsers, file managers, text
    editors or terminals. It does not aim to replace :class:`Gtk.Notebook` for use
    cases such as tabbed dialogs.

    As such, it does not support disabling page reordering or detaching.

    :class:`Adw.TabView` adds a number of global page switching and reordering shortcuts.
    The :attr:`TabView.shortcuts` property can be used to manage them.

    See :class:`TabViewShortcuts` for the list of the available shortcuts. All of
    the shortcuts are enabled by default.

    :meth:`TabView.add_shortcuts` and :meth:`TabView.remove_shortcuts` can be
    used to manage shortcuts in a convenient way, for example:

    .. code-block:: c

        :meth:`Adw.TabView.remove_shortcuts` (view, ADW_TAB_VIEW_SHORTCUT_CONTROL_HOME |
                                             ADW_TAB_VIEW_SHORTCUT_CONTROL_END);

    ## CSS nodes

    :class:`Adw.TabView` has a main CSS node with the name ``tabview``.

    ## Accessibility

    :class:`Adw.TabView` uses the :class:`Gtk.AccessibleRole.tab-panel` role for the tab
    pages which are the accessible parent objects of the child widgets.
    """
    gimeta: ClassVar[_GIMeta]
    default_icon: Gio.Icon
    is_transferring_page: bool
    menu_model: Gio.MenuModel
    n_pages: int
    n_pinned_pages: int
    pages: Gtk.SelectionModel
    selected_page: TabPage
    shortcuts: TabViewShortcuts | int
    def __init__(self, *, default_icon: Gio.Icon = ..., menu_model: Gio.MenuModel = ..., selected_page: TabPage = ..., shortcuts: TabViewShortcuts | int = ..., **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    def add_page(self, child: Gtk.Widget, parent: TabPage | None = ...) -> TabPage:
        """
        Adds ``child`` to ``self`` with ``parent`` as the parent.

        This function can be used to automatically position new pages, and to select
        the correct page when this page is closed while being selected (see
        :meth:`TabView.close_page`).

        If ``parent`` is ``None``, this function is equivalent to :meth:`TabView.append`.
        """
    def add_shortcuts(self, shortcuts: TabViewShortcuts | int) -> None:
        """
        Adds ``shortcuts`` for ``self``.

        See :attr:`TabView.shortcuts` for details.
        """
    def append(self, child: Gtk.Widget) -> TabPage:
        """
        Inserts ``child`` as the last non-pinned page.
        """
    def append_pinned(self, child: Gtk.Widget) -> TabPage:
        """
        Inserts ``child`` as the last pinned page.
        """
    def close_other_pages(self, page: TabPage) -> None:
        """
        Requests to close all pages other than ``page``.
        """
    def close_page_finish(self, page: TabPage, confirm: bool) -> None:
        """
        Completes a :meth:`TabView.close_page` call for ``page``.

        If ``confirm`` is ``True``, ``page`` will be closed. If it's ``False``, it will be
        reverted to its previous state and :meth:`TabView.close_page` can be called
        for it again.

        This function should not be called unless a custom handler for
        ``TabView::close-page`` is used.
        """
    def close_pages_after(self, page: TabPage) -> None:
        """
        Requests to close all pages after ``page``.
        """
    def close_pages_before(self, page: TabPage) -> None:
        """
        Requests to close all pages before ``page``.
        """
    def get_default_icon(self) -> Gio.Icon:
        """
        Gets the default icon of ``self``.
        """
    def get_is_transferring_page(self) -> bool:
        """
        Whether a page is being transferred.

        The corresponding property will be set to ``True`` when a drag-n-drop tab
        transfer starts on any :class:`Adw.TabView`, and to ``False`` after it ends.

        During the transfer, children cannot receive pointer input and a tab can
        be safely dropped on the tab view.
        """
    def get_menu_model(self) -> Gio.MenuModel | None:
        """
        Gets the tab context menu model for ``self``.
        """
    def get_n_pages(self) -> int:
        """
        Gets the number of pages in ``self``.
        """
    def get_n_pinned_pages(self) -> int:
        """
        Gets the number of pinned pages in ``self``.

