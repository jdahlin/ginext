        If the application's license is not in the list,
        :attr:`AboutDialog.license` can be used instead. The license type will be
        automatically set to :class:`Gtk.License.custom` in that case.

        If ``license_type`` is :class:`Gtk.License.unknown`, no information will be
        displayed.

        If ``license_type`` is different from :class:`Gtk.License.custom`.
        :attr:`AboutDialog.license` will be cleared out.

        The license description will be displayed on the Legal page, below the
        copyright information.

        :meth:`AboutDialog.add_legal_section` can be used to add license information
        for the application dependencies or other components.
        """
    def set_release_notes(self, release_notes: str) -> None:
        """
        Sets the release notes for ``self``.

        Release notes are displayed on the the What's New page.

        Release notes are formatted the same way as
        `AppStream descriptions <https://freedesktop.org/software/appstream/docs/chap-Metadata.html#tag-description>`_.

        The supported formatting options are:

        * Paragraph (``<p>``)
        * Ordered list (``<ol>``), with list items (``<li>``)
        * Unordered list (``<ul>``), with list items (``<li>``)

        Within paragraphs and list items, emphasis (``<em>``) and inline code
        (``<code>``) text styles are supported. The emphasis is rendered in italic,
        while inline code is shown in a monospaced font.

        Any text outside paragraphs or list items is ignored.

        Nested lists are not supported.

        :class:`Adw.AboutDialog` displays the version above the release notes. If set, the
        :attr:`AboutDialog.release-notes-version` of the property will be used
        as the version; otherwise, :attr:`AboutDialog.version` is used.
        """
    def set_release_notes_version(self, version: str) -> None:
        """
        Sets the version described by the application's release notes.

        The release notes version is displayed on the What's New page, above the
        release notes.

        If not set, :attr:`AboutDialog.version` will be used instead.

        For example, an application with the current version 2.0.2 might want to
        keep the release notes from 2.0.0, and set the release notes version
        accordingly.

        See :attr:`AboutDialog.release-notes`.
        """
    def set_support_url(self, support_url: str) -> None:
        """
        Sets the URL of the support page for ``self``.

        The support page link is displayed on the main page.
        """
    def set_translator_credits(self, translator_credits: str) -> None:
        """
        Sets the translator credits string.

        It will be displayed on the Credits page.

        This string should be ``"translator-credits"`` or ``"translator_credits"`` and
        should be marked as translatable.

        The string may contain email addresses and URLs, see the introduction for
        more details. When there is more than one translator, they must be
        separated by a newline in the same string.

        See also:

        * :attr:`AboutDialog.developers`
        * :attr:`AboutDialog.designers`
        * :attr:`AboutDialog.artists`
        * :attr:`AboutDialog.documenters`
        * :meth:`AboutDialog.add_credit_section`
        * :meth:`AboutDialog.add_acknowledgement_section`
        """
    def set_version(self, version: str) -> None:
        """
        Sets the version for ``self``.

        The version is displayed on the main page.

        If :attr:`AboutDialog.release-notes-version` is not set, the version will
        also be displayed above the release notes on the What's New page.
        """
    def set_website(self, website: str) -> None:
        """
        Sets the application website URL for ``self``.

        Website is displayed on the Details page, below comments, or on the main page
        if the Details page doesn't have any other content.

        Applications can add other links below, see :meth:`AboutDialog.add_link`.
        """
