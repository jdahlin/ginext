class Viewport(Widget, Accessible, Buildable, ConstraintTarget, Scrollable):
    """
    Implements scrollability for widgets that don't support scrolling
    on their own.

    Use :class:`Gtk.Viewport` to scroll child widgets such as :class:`Gtk.Grid`,
    :class:`Gtk.Box`, and so on.

    The :class:`Gtk.Viewport` will start scrolling content only if allocated
    less than the child widget’s minimum size in a given orientation.

    # CSS nodes

