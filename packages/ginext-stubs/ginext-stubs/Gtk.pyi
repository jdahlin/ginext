class SortListModel(GObject.Object, Gio.ListModel[_T], SectionModel):
    """
    A list model that sorts the elements of another model.

    The elements are sorted according to a :class:`Gtk.Sorter`.

    The model is a stable sort. If two items compare equal according
    to the sorter, the one that appears first in the original model will
    also appear first after sorting.

    Note that if you change the sorter, the previous order will have no
    influence on the new order. If you want that, consider using a
    :class:`Gtk.MultiSorter` and appending the previous sorter to it.

    The model can be set up to do incremental sorting, so that
    sorting long lists doesn't block the UI. See
    :meth:`Gtk.SortListModel.set_incremental` for details.

    :class:`Gtk.SortListModel` is a generic model and because of that it
    cannot take advantage of any external knowledge when sorting.
    If you run into performance issues with :class:`Gtk.SortListModel`,
    it is strongly recommended that you write your own sorting list
    model.

    :class:`Gtk.SortListModel` allows sorting the items into sections. It
    implements :class:`Gtk.SectionModel` and when :attr:`Gtk.SortListModel.section-sorter`
    is set, it will sort all items with that sorter and items comparing
    equal with it will be put into the same section.
    The :attr:`Gtk.SortListModel.sorter` will then be used to sort items
    inside their sections.
    """
    gimeta: ClassVar[_GIMeta]
    incremental: bool
    item_type: type[_T]
    model: Gio.ListModel[_T]
    n_items: int
    pending: int
    section_sorter: Sorter
    sorter: Sorter
    def __init__(self, *, incremental: bool = ..., model: Gio.ListModel[_T] = ..., section_sorter: Sorter = ..., sorter: Sorter = ..., **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    def get_incremental(self) -> bool:
        """
        Returns whether incremental sorting is enabled.

        See :meth:`Gtk.SortListModel.set_incremental`.
        """
    def get_model(self) -> Gio.ListModel[_T] | None:
        """
        Gets the model currently sorted or ``None`` if none.
        """
    def get_pending(self) -> int:
        """
        Estimates progress of an ongoing sorting operation.

        The estimate is the number of items that would still need to be
        sorted to finish the sorting operation if this was a linear
        algorithm. So this number is not related to how many items are
        already correctly sorted.

        If you want to estimate the progress, you can use code like this:
        .. code-block:: c

            pending = :meth:`Gtk.SortListModel.get_pending` (self);
            model = :meth:`Gtk.SortListModel.get_model` (self);
            progress = 1.0 - pending / (double) MAX (1, g_list_model_get_n_items (model));

