        Marks the next buffer as discontinuous and resets timestamp tracking.
        """
    def process(self, discont: bool, timestamp: Gst.ClockTime, n_samples: int) -> tuple[bool, Gst.ClockTime, Gst.ClockTime, int]:
        """
