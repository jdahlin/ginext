            {
              :class:`Gtk.FileChooser` *chooser = GTK_FILE_CHOOSER (native);
              GFile *file = :meth:`Gtk.FileChooser.get_file` (chooser);

              open_file (file);

              g_object_unref (file);
            }

          g_object_unref (native);
        }

          // ...
          :class:`Gtk.FileChooserNative` *native;
          :class:`Gtk.FileChooserAction` action = GTK_FILE_CHOOSER_ACTION_OPEN;

          native = :meth:`Gtk.FileChooserNative.new` ("Open File",
                                                parent_window,
                                                action,
                                                "_Open",
                                                "_Cancel");

