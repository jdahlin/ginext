          <child type="action">
            <object class=":class:`Gtk.Button`" id="button_cancel"/>
          </child>
          <child type="action">
            <object class=":class:`Gtk.Button`" id="button_ok">
            </object>
          </child>
          <action-widgets>
            <action-widget response="cancel">button_cancel</action-widget>
            <action-widget response="ok" default="true">button_ok</action-widget>
