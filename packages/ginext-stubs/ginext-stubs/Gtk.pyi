    area to display a circle in the normal widget foreground
    color.

    ## Simple :class:`Gtk.DrawingArea` usage

    .. code-block:: c

        static void
        draw_function (:class:`Gtk.DrawingArea` *area,
                       cairo_t        *cr,
                       int             width,
                       int             height,
                       gpointer        data)
        {
          GdkRGBA color;

          cairo_arc (cr,
                     width / 2.0, height / 2.0,
                     MIN (width, height) / 2.0,
                     0, 2 * G_PI);

          :meth:`Gtk.Widget.get_color` (GTK_WIDGET (area),
                                &color);
          gdk_cairo_set_source_rgba (cr, &color);

          cairo_fill (cr);
        }

        int
        main (int argc, char **argv)
        {
          :func:`Gtk.init`;

          :class:`Gtk.Widget` *area = :meth:`Gtk.DrawingArea.new`;
          :meth:`Gtk.DrawingArea.set_content_width` (GTK_DRAWING_AREA (area), 100);
          :meth:`Gtk.DrawingArea.set_content_height` (GTK_DRAWING_AREA (area), 100);
          :meth:`Gtk.DrawingArea.set_draw_func` (GTK_DRAWING_AREA (area),
                                          draw_function,
                                          NULL, NULL);
