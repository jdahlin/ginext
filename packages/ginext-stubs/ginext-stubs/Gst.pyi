             :meth:`Gst.Message.parse_device_removed` (message, &device);
             name = :meth:`Gst.Device.get_display_name` (device);
             g_print("Device removed: ``s``\\n", name);
             g_free (name);
             :meth:`Gst.Object.unref` (device);
             break;
           default:
             break;
         }

         return G_SOURCE_CONTINUE;
      }

      :class:`Gst.DeviceMonitor` *
      setup_raw_video_source_device_monitor (void) {
         :class:`Gst.DeviceMonitor` *monitor;
         :class:`Gst.Bus` *bus;
         :class:`Gst.Caps` *caps;

         monitor = :meth:`Gst.DeviceMonitor.new`;

         bus = :meth:`Gst.DeviceMonitor.get_bus` (monitor);
         gst_bus_add_watch (bus, my_bus_func, NULL);
         :meth:`Gst.Object.unref` (bus);

         caps = :meth:`Gst.Caps.new_empty_simple` ("video/x-raw");
         :meth:`Gst.DeviceMonitor.add_filter` (monitor, "Video/Source", caps);
