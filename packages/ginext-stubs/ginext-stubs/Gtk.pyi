        """

class StackSwitcher(Widget, Accessible, Buildable, ConstraintTarget, Orientable):
    """
    Shows a row of buttons to switch between :class:`Gtk.Stack` pages.

    <picture>
      <source srcset="stackswitcher-dark.png" media="(prefers-color-scheme: dark)">
      <img alt="An example :class:`Gtk.StackSwitcher`" src="stackswitcher.png">
    </picture>

    It acts as a controller for the associated :class:`Gtk.Stack`.

    All the content for the buttons comes from the properties of the stacks
    :class:`Gtk.StackPage` objects; the button visibility in a :class:`Gtk.StackSwitcher`
    widget is controlled by the visibility of the child in the :class:`Gtk.Stack`.

    It is possible to associate multiple :class:`Gtk.StackSwitcher` widgets
    with the same :class:`Gtk.Stack` widget.

    # CSS nodes

    :class:`Gtk.StackSwitcher` has a single CSS node named stackswitcher and
    style class .stack-switcher.

    When circumstances require it, :class:`Gtk.StackSwitcher` adds the
    .needs-attention style class to the widgets representing the
    stack pages.

    # Accessibility

    :class:`Gtk.StackSwitcher` uses the :class:`Gtk.AccessibleRole.tab_list` role
    and uses the :class:`Gtk.AccessibleRole.tab` role for its buttons.

    # Orientable

    Since GTK 4.4, :class:`Gtk.StackSwitcher` implements :class:`Gtk.Orientable` allowing
    the stack switcher to be made vertical with
    :meth:`Gtk.Orientable.set_orientation`.
    """
    gimeta: ClassVar[_GIMeta]
    stack: Stack
    def __init__(self, *, stack: Stack = ..., **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    def get_stack(self) -> Stack | None:
        """
        Retrieves the stack.
        """
    def set_stack(self, stack: Stack | None = ...) -> None:
        """
        Sets the stack to control.
        """

@deprecated("Deprecated since 4.10.")
class Statusbar(Widget, Accessible, Buildable, ConstraintTarget):
    """
    A :class:`Gtk.Statusbar` widget is usually placed along the bottom of an application's
    main :class:`Gtk.Window`.

    <picture>
      <source srcset="statusbar-dark.png" media="(prefers-color-scheme: dark)">
      <img alt="An example :class:`Gtk.Statusbar`" src="statusbar.png">
    </picture>

    A ``GtkStatusBar`` may provide a regular commentary of the application's
    status (as is usually the case in a web browser, for example), or may be
    used to simply output a message when the status changes, (when an upload
