    change_value: Signal[Self, [ScrollType], None]
    input: Signal[Self, [], int]
    output: Signal[Self, [], bool]
    value_changed: Signal[Self, [], None]
    wrapped: Signal[Self, [], None]
    def do_activate(self) -> None: ...
    def do_change_value(self, scroll: ScrollType) -> None: ...
    def do_input(self) -> int: ...
    def do_output(self) -> bool: ...
    def do_value_changed(self) -> None: ...
