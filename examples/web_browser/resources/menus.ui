<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">_New Tab</attribute>
        <attribute name="action">win.new-tab</attribute>
        <attribute name="accel">&lt;Primary&gt;t</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">New _Window</attribute>
        <attribute name="action">app.new-window</attribute>
        <attribute name="accel">&lt;Primary&gt;n</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">_Reload</attribute>
        <attribute name="action">win.reload</attribute>
        <attribute name="accel">&lt;Primary&gt;r</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Reload Without Cache</attribute>
        <attribute name="action">win.reload-bypass-cache</attribute>
        <attribute name="accel">&lt;Primary&gt;&lt;Shift&gt;r</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Stop</attribute>
        <attribute name="action">win.stop</attribute>
        <attribute name="accel">Escape</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Find in Page…</attribute>
        <attribute name="action">win.find</attribute>
        <attribute name="accel">&lt;Primary&gt;f</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Zoom _In</attribute>
        <attribute name="action">win.zoom-in</attribute>
        <attribute name="accel">&lt;Primary&gt;plus</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Zoom _Out</attribute>
        <attribute name="action">win.zoom-out</attribute>
        <attribute name="accel">&lt;Primary&gt;minus</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Normal Size</attribute>
        <attribute name="action">win.zoom-reset</attribute>
        <attribute name="accel">&lt;Primary&gt;0</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Mute Tab</attribute>
        <attribute name="action">win.toggle-mute</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">_Bookmark This Page</attribute>
        <attribute name="action">win.bookmark</attribute>
        <attribute name="accel">&lt;Primary&gt;d</attribute>
      </item>
      <submenu>
        <attribute name="label" translatable="yes">_Bookmarks</attribute>
        <section id="bookmarks_section"/>
        <section>
          <item>
            <attribute name="label" translatable="yes">Clear Bookmarks</attribute>
            <attribute name="action">win.clear-bookmarks</attribute>
          </item>
        </section>
      </submenu>
      <submenu>
        <attribute name="label" translatable="yes">_History</attribute>
        <section id="history_section"/>
        <section>
          <item>
            <attribute name="label" translatable="yes">Clear History</attribute>
            <attribute name="action">win.clear-history</attribute>
          </item>
        </section>
      </submenu>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">_Inspector</attribute>
        <attribute name="action">win.inspect</attribute>
        <attribute name="accel">&lt;Primary&gt;&lt;Shift&gt;i</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Print…</attribute>
        <attribute name="action">win.print</attribute>
        <attribute name="accel">&lt;Primary&gt;p</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Save Page Archive</attribute>
        <attribute name="action">win.save-page</attribute>
        <attribute name="accel">&lt;Primary&gt;s</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Extensions</attribute>
        <attribute name="action">win.extensions</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Reload Extensions</attribute>
        <attribute name="action">win.reload-extensions</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Clear Website Data</attribute>
        <attribute name="action">win.clear-website-data</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Show Cookies</attribute>
        <attribute name="action">win.cookies</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Show Website Data</attribute>
        <attribute name="action">win.website-data</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Terminate Web Process</attribute>
        <attribute name="action">win.terminate-web-process</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Settings</attribute>
        <attribute name="action">win.preferences</attribute>
        <attribute name="accel">&lt;Primary&gt;comma</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">_About Web Browser</attribute>
        <attribute name="action">app.about</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Quit</attribute>
        <attribute name="action">app.quit</attribute>
        <attribute name="accel">&lt;Primary&gt;q</attribute>
      </item>
    </section>
  </menu>

  <menu id="history_menu">
    <section id="history_dropdown_section"/>
  </menu>
</interface>
