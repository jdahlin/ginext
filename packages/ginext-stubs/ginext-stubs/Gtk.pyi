        """
    def get_hscroll_policy(self) -> ScrollablePolicy:
        """
        Gets the horizontal :class:`Gtk.ScrollablePolicy`.
        """
    def get_vadjustment(self) -> Adjustment | None:
        """
        Retrieves the :class:`Gtk.Adjustment` used for vertical scrolling.
        """
    def get_vscroll_policy(self) -> ScrollablePolicy:
        """
        Gets the vertical :class:`Gtk.ScrollablePolicy`.
