    def __init__(self, **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    allow_mechanism: SignalMethod[Self, [str], bool]
    authorize_authenticated_peer: SignalMethod[Self, [IOStream, Credentials | None], bool]
