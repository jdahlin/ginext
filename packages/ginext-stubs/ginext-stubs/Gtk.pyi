class WindowControls(Widget, Accessible, Buildable, ConstraintTarget):
    """
    Shows window frame controls.

    Typical window frame controls are minimize, maximize and close buttons,
    and the window icon.

    <picture>
      <source srcset="windowcontrols-dark.png" media="(prefers-color-scheme: dark)">
      <img alt="An example :class:`Gtk.WindowControls`" src="windowcontrols.png">
    </picture>

    :class:`Gtk.WindowControls` only displays start or end side of the controls (see
    :attr:`Gtk.WindowControls.side`), so it's intended to be always used
    in pair with another :class:`Gtk.WindowControls` for the opposite side, for example:

    .. code-block:: xml

        <object class=":class:`Gtk.Box`">
          <child>
            <object class=":class:`Gtk.WindowControls`">
              <property name="side">start</property>
            </object>
          </child>

          ...

          <child>
            <object class=":class:`Gtk.WindowControls`">
              <property name="side">end</property>
            </object>
          </child>
        </object>

    # CSS nodes

    .. code-block:: text

        windowcontrols
        ├── [image.icon]
        ├── [button.minimize]
        ├── [button.maximize]
        ╰── [button.close]

    A :class:`Gtk.WindowControls`' CSS node is called windowcontrols. It contains
    subnodes corresponding to each title button. Which of the title buttons
    exist and where they are placed exactly depends on the desktop environment
    and :attr:`Gtk.WindowControls.decoration-layout` value.

    When :attr:`Gtk.WindowControls.empty` is true, it gets the .empty
    style class.

    # Accessibility

    :class:`Gtk.WindowControls` uses the :class:`Gtk.AccessibleRole.group` role.
    """
    gimeta: ClassVar[_GIMeta]
    decoration_layout: str
    empty: bool
    side: PackType | int
    use_native_controls: bool
    def __init__(self, *, decoration_layout: str = ..., side: PackType | int = ..., use_native_controls: bool = ..., **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    def get_decoration_layout(self) -> str | None:
        """
        Gets the decoration layout of this window controls widget
        """
    def get_empty(self) -> bool:
        """
        Gets whether the widget has any window buttons.
        """
    def get_side(self) -> PackType:
        """
        Gets the side to which this window controls widget belongs.
        """
    def get_use_native_controls(self) -> bool:
        """
        Returns whether platform native window controls are shown.
        """
    def set_decoration_layout(self, layout: str | None = ...) -> None:
        """
        Sets the decoration layout for the title buttons.

        This overrides the :attr:`Gtk.Settings.gtk-decoration-layout`
        setting.

        The format of the string is button names, separated by commas.
        A colon separates the buttons that should appear on the left
        from those on the right. Recognized button names are minimize,
        maximize, close and icon (the window icon).

        For example, “icon:minimize,maximize,close” specifies a icon
        on the left, and minimize, maximize and close buttons on the right.

        If :attr:`Gtk.WindowControls.side` value is :class:`Gtk.PackType.start`,
        ``self`` will display the part before the colon, otherwise after that.
        """
    def set_side(self, side: PackType | int) -> None:
        """
        Determines which part of decoration layout
        the window controls widget uses.

        See :attr:`Gtk.WindowControls.decoration-layout`.
        """
    def set_use_native_controls(self, setting: bool) -> None:
        """
        Sets whether platform native window controls are used.

        This option shows the "stoplight" buttons on macOS.
        For Linux, this option has no effect.

        See also [Using GTK on Apple macOS](osx.html?native-window-controls).
        """

