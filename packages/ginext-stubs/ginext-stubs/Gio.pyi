          g_autoptr(:class:`Gio.DBusConnection`) connection = :func:`Gio.bus_get_sync` (G_BUS_TYPE_SYSTEM, NULL, NULL);
          gulong debug_controller_authorize_id = 0;

          // Set up the debug controller.
          debug_controller = G_DEBUG_CONTROLLER (:meth:`Gio.DebugControllerDBus.new` (priv->connection, NULL, &child_error));
          if (debug_controller == NULL)
