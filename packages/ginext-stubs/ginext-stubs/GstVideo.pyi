def video_color_matrix_from_iso(value: int) -> VideoColorMatrix:
    """
    Converts the ``value`` to the :class:`GstVideo.VideoColorMatrix`
    The matrix coefficients (MatrixCoefficients) value is
    defined by "ISO/IEC 23001-8 Section 7.3 Table 4"
    and "ITU-T H.273 Table 4".
    "H.264 Table E-5" and "H.265 Table E.5" share the identical values.
    """
def video_color_matrix_get_Kr_Kb(matrix: VideoColorMatrix | int) -> tuple[bool, float, float]:
    """
    Get the coefficients used to convert between Y'PbPr and R'G'B' using ``matrix``.

    When:

    |[
      0.0 <= [Y',R',G',B'] <= 1.0)
      (-0.5 <= [Pb,Pr] <= 0.5)
    ]|

    the general conversion is given by:

    |[
      Y' = Kr*R' + (1-Kr-Kb)*G' + Kb*B'
      Pb = (B'-Y')/(2*(1-Kb))
      Pr = (R'-Y')/(2*(1-Kr))
    ]|

    and the other way around:

    |[
      R' = Y' + Cr*2*(1-Kr)
      G' = Y' - Cb*2*(1-Kb)*Kb/(1-Kr-Kb) - Cr*2*(1-Kr)*Kr/(1-Kr-Kb)
      B' = Y' + Cb*2*(1-Kb)
    ]|
    """
def video_color_matrix_to_iso(matrix: VideoColorMatrix | int) -> int:
    """
    Converts :class:`GstVideo.VideoColorMatrix` to the "matrix coefficients"
    (MatrixCoefficients) value defined by "ISO/IEC 23001-8 Section 7.3 Table 4"
    and "ITU-T H.273 Table 4".
    "H.264 Table E-5" and "H.265 Table E.5" share the identical values.
    """
def video_color_primaries_from_iso(value: int) -> VideoColorPrimaries:
    """
    Converts the ``value`` to the :class:`GstVideo.VideoColorPrimaries`
    The colour primaries (ColourPrimaries) value is
    defined by "ISO/IEC 23001-8 Section 7.1 Table 2" and "ITU-T H.273 Table 2".
    "H.264 Table E-3" and "H.265 Table E.3" share the identical values.
