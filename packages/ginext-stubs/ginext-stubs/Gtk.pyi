    parent_class: WidgetClass

class WindowGroup(GObject.Object):
    """
    Creates groups of windows that behave like separate applications.

    It achieves this by limiting the effect of GTK grabs and modality
    to windows in the same group.

    A window can be a member in at most one window group at a time.
    Windows that have not been explicitly assigned to a group are
    implicitly treated like windows of the default window group.

    :class:`Gtk.WindowGroup` objects are referenced by each window in the group,
    so once you have added all windows to a :class:`Gtk.WindowGroup`, you can drop
    the initial reference to the window group with g_object_unref(). If the
    windows in the window group are subsequently destroyed, then they will
    be removed from the window group and drop their references on the window
    group; when all window have been removed, the window group will be
    freed.
    """
    gimeta: ClassVar[_GIMeta]
    def __init__(self, **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    def add_window(self, window: Window) -> None:
        """
        Adds a window to a :class:`Gtk.WindowGroup`.
        """
    def list_windows(self) -> list[Window]:
        """
        Returns a list of the ``GtkWindows`` that belong to ``window_group``.
        """
    def remove_window(self, window: Window) -> None:
        """
        Removes a window from a :class:`Gtk.WindowGroup`.
        """

