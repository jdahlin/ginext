        following interface is provided:

        |[<!-- language="C" -->
        void
        start_counting (:class:`GLib.MarkupParseContext` *context)
        {
          CounterData *data = g_slice_new (CounterData);

          data->tag_count = 0;
          :meth:`GLib.MarkupParseContext.push` (context, &counter_subparser, data);
        }

        gint
        end_counting (:class:`GLib.MarkupParseContext` *context)
        {
          CounterData *data = :meth:`GLib.MarkupParseContext.pop` (context);
          int result;

          result = data->tag_count;
          g_slice_free (CounterData, data);

          return result;
        }
        ]|

        The subparser would then be used as follows:

        |[<!-- language="C" -->
        static void start_element (context, element_name, ...)
        {
          if (strcmp (element_name, "count-these") == 0)
            start_counting (context);

          // else, handle other tags...
        }

        static void end_element (context, element_name, ...)
        {
          if (strcmp (element_name, "count-these") == 0)
            g_print ("Counted ``d`` tags\\n", end_counting (context));

          // else, handle other tags...
        }
        ]|
        """
    def ref(self) -> MarkupParseContext:
        """
        Increases the reference count of ``context``.
        """
    def unref(self) -> None:
