    .. code-block:: c

        void
        selection_changed (:class:`Gtk.TreeSelection` *selection, gpointer data)
        {
          :class:`Gtk.TreeModel` *sort_model = NULL;
          :class:`Gtk.TreeModel` *child_model;
          :class:`Gtk.TreeIter` sort_iter;
          :class:`Gtk.TreeIter` child_iter;
