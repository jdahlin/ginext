        """
        Copy a :class:`GstAudio.AudioStreamAlign` structure.
        """
    def free(self) -> None:
        """
        Free a :class:`GstAudio.AudioStreamAlign` structure previously allocated with :meth:`GstAudio.AudioStreamAlign.new`
