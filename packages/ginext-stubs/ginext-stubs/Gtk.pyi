    [overview](section-list-widget.html).

    An example of using :class:`Gtk.ListView`:
    .. code-block:: c

        static void
        setup_listitem_cb (:class:`Gtk.ListItemFactory` *factory,
                           :class:`Gtk.ListItem`        *list_item)
        {
          :class:`Gtk.Widget` *image;

          image = :meth:`Gtk.Image.new`;
          :meth:`Gtk.Image.set_icon_size` (GTK_IMAGE (image), GTK_ICON_SIZE_LARGE);
          :meth:`Gtk.ListItem.set_child` (list_item, image);
        }

        static void
        bind_listitem_cb (:class:`Gtk.ListItemFactory` *factory,
                          :class:`Gtk.ListItem`        *list_item)
        {
          :class:`Gtk.Widget` *image;
          GAppInfo *app_info;

          image = :meth:`Gtk.ListItem.get_child` (list_item);
          app_info = :meth:`Gtk.ListItem.get_item` (list_item);
          :meth:`Gtk.Image.set_from_gicon` (GTK_IMAGE (image), g_app_info_get_icon (app_info));
        }

        static void
        activate_cb (:class:`Gtk.ListView`  *list,
                     guint         position,
                     gpointer      unused)
        {
          GAppInfo *app_info;

          app_info = g_list_model_get_item (G_LIST_MODEL (:meth:`Gtk.ListView.get_model` (list)), position);
          g_app_info_launch (app_info, NULL, NULL, NULL);
          g_object_unref (app_info);
        }

        ...

          model = create_application_list ();

          factory = :meth:`Gtk.SignalListItemFactory.new`;
          g_signal_connect (factory, "setup", G_CALLBACK (setup_listitem_cb), NULL);
          g_signal_connect (factory, "bind", G_CALLBACK (bind_listitem_cb), NULL);

          list = :meth:`Gtk.ListView.new` (GTK_SELECTION_MODEL (:meth:`Gtk.SingleSelection.new` (model)), factory);

          g_signal_connect (list, "activate", G_CALLBACK (activate_cb), NULL);

          :meth:`Gtk.ScrolledWindow.set_child` (GTK_SCROLLED_WINDOW (sw), list);

    # Actions

    :class:`Gtk.ListView` defines a set of built-in actions:

    - ``list.activate-item`` activates the item at given position by emitting
