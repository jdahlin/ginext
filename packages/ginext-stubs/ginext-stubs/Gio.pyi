class DBusAuthObserver(GObject.Object):
    """
    :class:`Gio.DBusAuthObserver` provides a mechanism for participating
    in how a :class:`Gio.DBusServer` (or a :class:`Gio.DBusConnection`)
    authenticates remote peers.

