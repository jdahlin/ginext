class MenuButton(Widget, Accessible, Buildable, ConstraintTarget):
    """
    Displays a popup when clicked.

    <picture>
      <source srcset="menu-button-dark.png" media="(prefers-color-scheme: dark)">
      <img alt="An example :class:`Gtk.MenuButton`" src="menu-button.png">
    </picture>

    This popup can be provided either as a :class:`Gtk.Popover` or as an abstract
    ``GMenuModel``.

    The :class:`Gtk.MenuButton` widget can show either an icon (set with the
    :attr:`Gtk.MenuButton.icon-name` property) or a label (set with the
    :attr:`Gtk.MenuButton.label` property). If neither is explicitly set,
    a :class:`Gtk.Image` is automatically created, using an arrow image oriented
    according to :attr:`Gtk.MenuButton.direction` or the generic
    “open-menu-symbolic” icon if the direction is not set.

    The positioning of the popup is determined by the
    :attr:`Gtk.MenuButton.direction` property of the menu button.

    For menus, the :attr:`Gtk.Widget.halign` and :attr:`Gtk.Widget.valign`
    properties of the menu are also taken into account. For example, when the
    direction is :data:`Gtk.ArrowType.DOWN` and the horizontal alignment is :data:`Gtk.Align.START`,
    the menu will be positioned below the button, with the starting edge
    (depending on the text direction) of the menu aligned with the starting
    edge of the button. If there is not enough space below the button, the
    menu is popped up above the button instead. If the alignment would move
    part of the menu offscreen, it is “pushed in”.

    |           | start                | center                | end                |
    | -         | ---                  | ---                   | ---                |
    | **down**  | ![](down-start.png)  | ![](down-center.png)  | ![](down-end.png)  |
    | **up**    | ![](up-start.png)    | ![](up-center.png)    | ![](up-end.png)    |
    | **left**  | ![](left-start.png)  | ![](left-center.png)  | ![](left-end.png)  |
    | **right** | ![](right-start.png) | ![](right-center.png) | ![](right-end.png) |

    # CSS nodes

    .. code-block:: text

        menubutton
        ╰── button.toggle
            ╰── <content>
                 ╰── [arrow]

    :class:`Gtk.MenuButton` has a single CSS node with name ``menubutton``
    which contains a ``button`` node with a ``.toggle`` style class.

    If the button contains an icon, it will have the ``.image-button`` style class,
    if it contains text, it will have ``.text-button`` style class. If an arrow is
    visible in addition to an icon, text or a custom child, it will also have
    ``.arrow-button`` style class.

    Inside the toggle button content, there is an ``arrow`` node for
    the indicator, which will carry one of the ``.none``, ``.up``, ``.down``,
    ``.left`` or ``.right`` style classes to indicate the direction that
    the menu will appear in. The CSS is expected to provide a suitable
    image for each of these cases using the ``-gtk-icon-source`` property.

    Optionally, the ``menubutton`` node can carry the ``.circular`` style class
    to request a round appearance.

    # Accessibility

    :class:`Gtk.MenuButton` uses the :class:`Gtk.AccessibleRole.button` role.
    """
    gimeta: ClassVar[_GIMeta]
    active: bool
    always_show_arrow: bool
    can_shrink: bool
    child: Widget
    direction: ArrowType | int
    has_frame: bool
    icon_name: str
    label: str
    menu_model: Gio.MenuModel
    popover: Popover
    primary: bool
    use_underline: bool
    def __init__(self, *, active: bool = ..., always_show_arrow: bool = ..., can_shrink: bool = ..., child: Widget = ..., direction: ArrowType | int = ..., has_frame: bool = ..., icon_name: str = ..., label: str = ..., menu_model: Gio.MenuModel = ..., popover: Popover = ..., primary: bool = ..., use_underline: bool = ..., **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    def get_active(self) -> bool:
        """
        Returns whether the menu button is active.
        """
    def get_always_show_arrow(self) -> bool:
        """
        Gets whether to show a dropdown arrow even when using an icon or a custom
        child.
        """
    def get_can_shrink(self) -> bool:
        """
        Retrieves whether the button can be smaller than the natural
        size of its contents.
        """
    def get_child(self) -> Widget | None:
        """
        Gets the child widget of ``menu_button``.
        """
    def get_direction(self) -> ArrowType:
        """
        Returns the direction the popup will be pointing at when popped up.
        """
    def get_has_frame(self) -> bool:
        """
        Returns whether the button has a frame.
        """
    def get_icon_name(self) -> str | None:
        """
        Gets the name of the icon shown in the button.
        """
    def get_label(self) -> str | None:
        """
        Gets the label shown in the button
        """
    def get_menu_model(self) -> Gio.MenuModel | None:
        """
        Returns the ``GMenuModel`` used to generate the popup.
        """
    def get_popover(self) -> Popover | None:
        """
        Returns the :class:`Gtk.Popover` that pops out of the button.

        If the button is not using a :class:`Gtk.Popover`, this function
        returns ``None``.
        """
    def get_primary(self) -> bool:
        """
        Returns whether the menu button acts as a primary menu.
        """
    def get_use_underline(self) -> bool:
        """
        Returns whether an embedded underline in the text indicates a
        mnemonic.
        """
    def popdown(self) -> None:
        """
        Dismiss the menu.
        """
    def popup(self) -> None:
        """
        Pop up the menu.
        """
    def set_active(self, active: bool) -> None:
        """
        Sets whether the menu button is active.
        """
    def set_always_show_arrow(self, always_show_arrow: bool) -> None:
        """
        Sets whether to show a dropdown arrow even when using an icon or a custom
        child.
        """
    def set_can_shrink(self, can_shrink: bool) -> None:
        """
        Sets whether the button size can be smaller than the natural size of
        its contents.

        For text buttons, setting ``can_shrink`` to true will ellipsize the label.

        For icon buttons, this function has no effect.
        """
    def set_child(self, child: Widget | None = ...) -> None:
        """
        Sets the child widget of ``menu_button``.

        Setting a child resets :attr:`Gtk.MenuButton.label` and
        :attr:`Gtk.MenuButton.icon-name`.

        If :attr:`Gtk.MenuButton.always-show-arrow` is set to ``True`` and
        :attr:`Gtk.MenuButton.direction` is not ``GTK_ARROW_NONE``, a dropdown arrow
        will be shown next to the child.
        """
    def set_create_popup_func(self, func: MenuButtonCreatePopupFunc | None = ...) -> None:
        """
        Sets ``func`` to be called when a popup is about to be shown.

        ``func`` should use one of

         - :meth:`Gtk.MenuButton.set_popover`
         - :meth:`Gtk.MenuButton.set_menu_model`

        to set a popup for ``menu_button``.
        If ``func`` is non-``None``, ``menu_button`` will always be sensitive.

        Using this function will not reset the menu widget attached to
        ``menu_button``. Instead, this can be done manually in ``func``.
        """
    def set_direction(self, direction: ArrowType | int) -> None:
        """
        Sets the direction in which the popup will be popped up.

        If the button is automatically populated with an arrow icon,
        its direction will be changed to match.

        If the does not fit in the available space in the given direction,
        GTK will its best to keep it inside the screen and fully visible.

        If you pass :data:`Gtk.ArrowType.NONE` for a ``direction``, the popup will behave
        as if you passed :data:`Gtk.ArrowType.DOWN` (although you won’t see any arrows).
        """
    def set_has_frame(self, has_frame: bool) -> None:
        """
        Sets the style of the button.
        """
    def set_icon_name(self, icon_name: str) -> None:
        """
        Sets the name of an icon to show inside the menu button.

        Setting icon name resets :attr:`Gtk.MenuButton.label` and
        :attr:`Gtk.MenuButton.child`.

        If :attr:`Gtk.MenuButton.always-show-arrow` is set to ``True`` and
        :attr:`Gtk.MenuButton.direction` is not ``GTK_ARROW_NONE``, a dropdown arrow
        will be shown next to the icon.
        """
    def set_label(self, label: str) -> None:
        """
        Sets the label to show inside the menu button.

        Setting a label resets :attr:`Gtk.MenuButton.icon-name` and
        :attr:`Gtk.MenuButton.child`.

        If :attr:`Gtk.MenuButton.direction` is not ``GTK_ARROW_NONE``, a dropdown
        arrow will be shown next to the label.
        """
    def set_menu_model(self, menu_model: Gio.MenuModel | None = ...) -> None:
        """
        Sets the ``GMenuModel`` from which the popup will be constructed.

        If ``menu_model`` is ``None``, the button is disabled.

        A :class:`Gtk.Popover` will be created from the menu model with
        :meth:`Gtk.PopoverMenu.new_from_model`. Actions will be connected
        as documented for this function.

        If :attr:`Gtk.MenuButton.popover` is already set, it will be
        dissociated from the ``menu_button``, and the property is set to ``None``.
        """
    def set_popover(self, popover: Popover | None = ...) -> None:
        """
        Sets the :class:`Gtk.Popover` that will be popped up when the ``menu_button`` is clicked.

        If ``popover`` is ``None``, the button is disabled.

        If :attr:`Gtk.MenuButton.menu-model` is set, the menu model is dissociated
        from the ``menu_button``, and the property is set to ``None``.
        """
    def set_primary(self, primary: bool) -> None:
        """
        Sets whether menu button acts as a primary menu.

        Primary menus can be opened with the <kbd>F10</kbd> key.
        """
    def set_use_underline(self, use_underline: bool) -> None:
        """
        If true, an underline in the text indicates a mnemonic.
        """
    activate: SignalMethod[Self, [], None]
    def do_activate(self) -> None: ...

@deprecated("Deprecated since 4.10.")
class MessageDialog(Dialog, Accessible, Buildable, ConstraintTarget, Native, Root, ShortcutManager):
    """
    :class:`Gtk.MessageDialog` presents a dialog with some message text.

    <picture>
      <source srcset="messagedialog-dark.png" media="(prefers-color-scheme: dark)">
      <img alt="An example :class:`Gtk.MessageDialog`" src="messagedialog.png">
    </picture>

    It’s simply a convenience widget; you could construct the equivalent of
    :class:`Gtk.MessageDialog` from :class:`Gtk.Dialog` without too much effort, but
    :class:`Gtk.MessageDialog` saves typing.

    The easiest way to do a modal message dialog is to use the :data:`Gtk.DialogFlags.MODAL`
    flag, which will call :meth:`Gtk.Window.set_modal` internally. The dialog will
    prevent interaction with the parent window until it's hidden or destroyed.
    You can use the ``Gtk.Dialog::response`` signal to know when the user
    dismissed the dialog.

    An example for using a modal dialog:
    .. code-block:: c

        :class:`Gtk.DialogFlags` flags = GTK_DIALOG_DESTROY_WITH_PARENT | GTK_DIALOG_MODAL;
        dialog = gtk_message_dialog_new (parent_window,
                                         flags,
                                         GTK_MESSAGE_ERROR,
                                         GTK_BUTTONS_CLOSE,
                                         "Error reading “``s``”: ``s``",
                                         filename,
                                         g_strerror (errno));
        // Destroy the dialog when the user responds to it
        // (e.g. clicks a button)

        g_signal_connect (dialog, "response",
                          G_CALLBACK (:meth:`Gtk.Window.destroy`),
                          NULL);

    You might do a non-modal :class:`Gtk.MessageDialog` simply by omitting the
    :data:`Gtk.DialogFlags.MODAL` flag:

    .. code-block:: c

        :class:`Gtk.DialogFlags` flags = GTK_DIALOG_DESTROY_WITH_PARENT;
        dialog = gtk_message_dialog_new (parent_window,
                                         flags,
                                         GTK_MESSAGE_ERROR,
                                         GTK_BUTTONS_CLOSE,
                                         "Error reading “``s``”: ``s``",
                                         filename,
                                         g_strerror (errno));

        // Destroy the dialog when the user responds to it
        // (e.g. clicks a button)
        g_signal_connect (dialog, "response",
                          G_CALLBACK (:meth:`Gtk.Window.destroy`),
                          NULL);

    # :class:`Gtk.MessageDialog` as :class:`Gtk.Buildable`

    The :class:`Gtk.MessageDialog` implementation of the :class:`Gtk.Buildable` interface exposes
    the message area as an internal child with the name “message_area”.
    """
    gimeta: ClassVar[_GIMeta]
    buttons: ButtonsType | int
    message_area: Widget
    message_type: MessageType | int
    secondary_text: str
    secondary_use_markup: bool
    text: str
    use_markup: bool
    def __init__(self, *, buttons: ButtonsType | int = ..., message_type: MessageType | int = ..., secondary_text: str = ..., secondary_use_markup: bool = ..., text: str = ..., use_markup: bool = ..., **kwargs: Any) -> None: ...
    @deprecated("Deprecated since 4.10.")
    def get_message_area(self) -> Widget:
        """
        Returns the message area of the dialog.

        This is the box where the dialog’s primary and secondary labels
        are packed. You can add your own extra content to that box and it
        will appear below those labels. See :meth:`Gtk.Dialog.get_content_area`
        for the corresponding function in the parent :class:`Gtk.Dialog`.
        """
    @deprecated("Deprecated since 4.10.")
    def set_markup(self, str: str) -> None:
        """
        Sets the text of the message dialog.
        """

