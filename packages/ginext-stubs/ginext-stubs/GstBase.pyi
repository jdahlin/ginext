    clip: Any
    finish_buffer: Any
    sink_event: Any
    sink_query: Any
    src_event: Any
    src_query: Any
    src_activate: Any
    aggregate: Any
    stop: Any
    start: Any
    get_next_time: Any
    create_new_pad: Any
    update_src_caps: Any
    fixate_src_caps: Any
    negotiated_src_caps: Any
    decide_allocation: Any
    propose_allocation: Any
    negotiate: Any
    sink_event_pre_queue: Any
    sink_query_pre_queue: Any
    finish_buffer_list: Any
    peek_next_sample: Any
    _gst_reserved: list[int]

