    is to provide a function via :meth:`Gsk.RenderReplay.set_node_filter`
    to filter each individual node and then run
    :meth:`Gsk.RenderReplay.filter_node` on the nodes you want to filter.

    If you want to just walk the node tree and extract information
    without any modifications, you can also use :meth:`Gsk.RenderNode.get_children`.

    Here is a little example application that redacts text in a node file:

    .. code-block:: text

        #include <gtk/gtk.h>

        static :class:`Gsk.RenderNode` *
        redact_nodes (:class:`Gsk.RenderReplay` *replay,
                      :class:`Gsk.RenderNode`   *node,
                      gpointer         user_data)
        {
          :class:`Gsk.RenderNode` *result;

          if (:meth:`Gsk.RenderNode.get_node_type` (node) == GSK_TEXT_NODE)
            {
              graphene_rect_t bounds;
              const GdkRGBA *color;

              :meth:`Gsk.RenderNode.get_bounds` (node, &bounds);
              color = :meth:`Gsk.TextNode.get_color` (node);

              result = :meth:`Gsk.ColorNode.new` (color, &bounds);
            }
          else
            {
              result = :meth:`Gsk.RenderReplay.default` (replay, node);
            }

          return result;
        }

        int
        main (int argc, char *argv[])
        {
          GFile *file;
          GBytes *bytes;
          :class:`Gsk.RenderNode` *result, *node;
          :class:`Gsk.RenderReplay` *replay;

          gtk_init ();

          if (argc != 3)
            {
              g_print ("usage: ``s`` INFILE OUTFILE\\n", argv[0]);
              return 0;
            }

          file = g_file_new_for_commandline_arg (argv[1]);
          bytes = g_file_load_bytes (file, NULL, NULL, NULL);
          g_object_unref (file);
          if (bytes == NULL)
            return 1;

          node = :meth:`Gsk.RenderNode.deserialize` (bytes, NULL, NULL);
          g_bytes_unref (bytes);
          if (node == NULL)
            return 1;

          replay = :meth:`Gsk.RenderReplay.new`;
          :meth:`Gsk.RenderReplay.set_node_filter` (replay, redact_nodes, NULL, NULL);
          result = :meth:`Gsk.RenderReplay.filter_node` (replay, node);
          :meth:`Gsk.RenderReplay.free` (replay);

          if (!:meth:`Gsk.RenderNode.write_to_file` (result, argv[2], NULL))
            return 1;

          :meth:`Gsk.RenderNode.unref` (result);
          :meth:`Gsk.RenderNode.unref` (node);

          return 0;
        }
