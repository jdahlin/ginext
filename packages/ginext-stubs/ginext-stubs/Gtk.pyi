class Switch(Widget, Accessible, Actionable, Buildable, ConstraintTarget):
    """
    Shows a "light switch" that has two states: on or off.

    <picture>
      <source srcset="switch-dark.png" media="(prefers-color-scheme: dark)">
      <img alt="An example :class:`Gtk.Switch`" src="switch.png">
    </picture>

    The user can control which state should be active by clicking the
    empty area, or by dragging the slider.

    :class:`Gtk.Switch` can also express situations where the underlying state changes
    with a delay. In this case, the slider position indicates the user's recent
    change (represented by the :attr:`Gtk.Switch.active` property), while the
    trough color indicates the present underlying state (represented by the
    :attr:`Gtk.Switch.state` property).

    <picture>
      <source srcset="switch-state-dark.png" media="(prefers-color-scheme: dark)">
      <img alt=":class:`Gtk.Switch` with delayed state change" src="switch-state.png">
    </picture>

    See ``Gtk.Switch::state-set`` for details.

    # Shortcuts and Gestures

    :class:`Gtk.Switch` supports pan and drag gestures to move the slider.

    # CSS nodes

    .. code-block:: text

        switch
        ├── image
        ├── image
        ╰── slider

    :class:`Gtk.Switch` has four css nodes, the main node with the name switch and
    subnodes for the slider and the on and off images. Neither of them is
    using any style classes.

    # Accessibility

    :class:`Gtk.Switch` uses the :class:`Gtk.AccessibleRole.switch` role.
    """
    gimeta: ClassVar[_GIMeta]
    active: bool
    state: bool
    def __init__(self, *, active: bool = ..., state: bool = ..., **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    def get_active(self) -> bool:
        """
        Gets whether the :class:`Gtk.Switch` is in its “on” or “off” state.
        """
    def get_state(self) -> bool:
        """
        Gets the underlying state of the :class:`Gtk.Switch`.
        """
    def set_active(self, is_active: bool) -> None:
        """
        Changes the state of ``self`` to the desired one.
        """
    def set_state(self, state: bool) -> None:
        """
        Sets the underlying state of the :class:`Gtk.Switch`.

        This function is typically called from a ``Gtk.Switch::state-set``
        signal handler in order to set up delayed state changes.

        See ``Gtk.Switch::state-set`` for details.
        """
