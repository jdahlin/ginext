    create_window: Signal[Self, [], TabView | None]
    indicator_activated: Signal[Self, [TabPage], None]
    page_attached: Signal[Self, [TabPage, int], None]
    page_detached: Signal[Self, [TabPage, int], None]
    page_reordered: Signal[Self, [TabPage, int], None]
    setup_menu: Signal[Self, [TabPage | None], None]
    def do_close_page(self, page: TabPage) -> bool: ...
    def do_create_window(self) -> TabView | None: ...
    def do_indicator_activated(self, page: TabPage) -> None: ...
    def do_page_attached(self, page: TabPage, position: int) -> None: ...
    def do_page_detached(self, page: TabPage, position: int) -> None: ...
    def do_page_reordered(self, page: TabPage, position: int) -> None: ...
    def do_setup_menu(self, page: TabPage | None) -> None: ...

