    .. code-block:: c

        static void
        on_save_response (:class:`Gtk.Dialog` *dialog,
                          int        response)
        {
          if (response == GTK_RESPONSE_ACCEPT)
            {
              :class:`Gtk.FileChooser` *chooser = GTK_FILE_CHOOSER (dialog);

              g_autoptr(GFile) file = :meth:`Gtk.FileChooser.get_file` (chooser);

              save_to_file (file);
            }

          :meth:`Gtk.Window.destroy` (GTK_WINDOW (dialog));
        }

          // ...
          :class:`Gtk.Widget` *dialog;
          :class:`Gtk.FileChooser` *chooser;
          :class:`Gtk.FileChooserAction` action = GTK_FILE_CHOOSER_ACTION_SAVE;

          dialog = gtk_file_chooser_dialog_new ("Save File",
                                                parent_window,
                                                action,
                                                _("_Cancel"),
                                                GTK_RESPONSE_CANCEL,
                                                _("_Save"),
                                                GTK_RESPONSE_ACCEPT,
                                                NULL);
          chooser = GTK_FILE_CHOOSER (dialog);

          if (user_edited_a_new_document)
            :meth:`Gtk.FileChooser.set_current_name` (chooser, _("Untitled document"));
          else
            :meth:`Gtk.FileChooser.set_file` (chooser, existing_filename);

          :meth:`Gtk.Window.present` (GTK_WINDOW (dialog));

