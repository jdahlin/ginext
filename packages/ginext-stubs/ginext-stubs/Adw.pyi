                │       ├── widget
                │       │   ╰── [button.back]
                │       ╰── [other children]
                ├── widget
                │   ╰── [Title Widget]
                ╰── widget
                    ╰── box.end
                        ├── [other children]
                        ╰── windowcontrols.end

