class ToggleButton(Button, Accessible, Actionable, Buildable, ConstraintTarget):
    """
    Shows a button which remains “pressed-in” when clicked.

    <picture>
      <source srcset="toggle-button-dark.png" media="(prefers-color-scheme: dark)">
      <img alt="Example GtkToggleButtons" src="toggle-button.png">
    </picture>

    Clicking again will cause the toggle button to return to its normal state.

    A toggle button is created by calling either :meth:`Gtk.ToggleButton.new` or
    :meth:`Gtk.ToggleButton.new_with_label`. If using the former, it is advisable
    to pack a widget, (such as a :class:`Gtk.Label` and/or a :class:`Gtk.Image`), into the toggle
    button’s container. (See :class:`Gtk.Button` for more information).

    The state of a :class:`Gtk.ToggleButton` can be set specifically using
    :meth:`Gtk.ToggleButton.set_active`, and retrieved using
    :meth:`Gtk.ToggleButton.get_active`.

    ## Grouping

    Toggle buttons can be grouped together, to form mutually exclusive
    groups - only one of the buttons can be toggled at a time, and toggling
    another one will switch the currently toggled one off.

    To add a :class:`Gtk.ToggleButton` to a group, use :meth:`Gtk.ToggleButton.set_group`.

    ## CSS nodes

    :class:`Gtk.ToggleButton` has a single CSS node with name button. To differentiate
    it from a plain :class:`Gtk.Button`, it gets the ``.toggle`` style class.

    ## Accessibility

    :class:`Gtk.ToggleButton` uses the :class:`Gtk.AccessibleRole.toggle_button` role.

    ## Creating two :class:`Gtk.ToggleButton` widgets.

    .. code-block:: c

        static void
        output_state (:class:`Gtk.ToggleButton` *source,
                      gpointer         user_data)
        {
          g_print ("Toggle button "``s``" is active: ``s``",
                   :meth:`Gtk.Button.get_label` (GTK_BUTTON (source)),
                   :meth:`Gtk.ToggleButton.get_active` (source) ? "Yes" : "No");
        }

        static void
        make_toggles (void)
        {
          :class:`Gtk.Widget` *window, *toggle1, *toggle2;
          :class:`Gtk.Widget` *box;
          const char *text;

          window = :meth:`Gtk.Window.new`;
          box = :meth:`Gtk.Box.new` (GTK_ORIENTATION_VERTICAL, 12);

          text = "Hi, I’m toggle button one";
          toggle1 = :meth:`Gtk.ToggleButton.new_with_label` (text);

          g_signal_connect (toggle1, "toggled",
                            G_CALLBACK (output_state),
                            NULL);
          :meth:`Gtk.Box.append` (GTK_BOX (box), toggle1);

          text = "Hi, I’m toggle button two";
          toggle2 = :meth:`Gtk.ToggleButton.new_with_label` (text);
          g_signal_connect (toggle2, "toggled",
                            G_CALLBACK (output_state),
                            NULL);
          :meth:`Gtk.Box.append` (GTK_BOX (box), toggle2);

          :meth:`Gtk.Window.set_child` (GTK_WINDOW (window), box);
          :meth:`Gtk.Window.present` (GTK_WINDOW (window));
        }
    """
    gimeta: ClassVar[_GIMeta]
    active: bool
    group: ToggleButton
    def __init__(self, *, active: bool = ..., group: ToggleButton = ..., **kwargs: Any) -> None: ...
    @classmethod
    def new(cls, *args: Any, **kwargs: Any) -> Self: ...
    @classmethod
    def new_with_label(cls, label: str) -> Self:
        """
        Creates a new toggle button with a text label.
        """
    @classmethod
    def new_with_mnemonic(cls, label: str) -> Self:
        """
        Creates a new :class:`Gtk.ToggleButton` containing a label.

        The label will be created using :meth:`Gtk.Label.new_with_mnemonic`,
