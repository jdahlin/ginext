        create_layout_child (:class:`Gtk.LayoutManager` *manager,
                             :class:`Gtk.Widget`        *container,
                             :class:`Gtk.Widget`        *child)
        {
          return g_object_new (your_layout_child_get_type (),
                               "layout-manager", manager,
                               "child-widget", child,
                               NULL);
