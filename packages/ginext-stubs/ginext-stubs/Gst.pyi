class Meta:
    """
    The :class:`Gst.Meta` structure should be included as the first member of a :class:`Gst.Buffer`
    metadata structure. The structure defines the API of the metadata and should
    be accessible to all elements using the metadata.

    A metadata API is registered with :func:`Gst.meta_api_type_register` which takes a
    name for the metadata API and some tags associated with the metadata.
    With :func:`Gst.meta_api_type_has_tag` one can check if a certain metadata API
    contains a given tag.

    Multiple implementations of a metadata API can be registered.
    To implement a metadata API, gst_meta_register() should be used. This
    function takes all parameters needed to create, free and transform metadata
    along with the size of the metadata. The function returns a :class:`Gst.MetaInfo`
    structure that contains the information for the implementation of the API.

    A specific implementation can be retrieved by name with :func:`Gst.meta_get_info`.

    See :class:`Gst.Buffer` for how the metadata can be added, retrieved and removed from
    buffers.
    """
    gimeta: ClassVar[_GIMeta]
    flags: MetaFlags | int
    info: MetaInfo
    def compare_seqnum(self, meta2: Meta) -> int:
        """
        Meta sequence number compare function. Can be used as :class:`GCompareFunc`
        or a :class:`GCompareDataFunc.`
        """
    def get_seqnum(self) -> int:
        """
        Gets seqnum for this meta.
        """
    def serialize(self, data: ByteArrayInterface) -> bool:
        """
        Serialize ``meta`` into a format that can be stored or transmitted and later
        deserialized by :func:`Gst.meta_deserialize`.

        This is only supported for meta that implements :class:`Gst.MetaInfo`.serialize_func,
        ``False`` is returned otherwise.

        Upon failure, ``data``->data pointer could have been reallocated, but ``data``->len
        won't be modified. This is intended to be able to append multiple metas
        into the same :class:`GByteArray.`

        Since serialization size is often the same for every buffer, caller may want
        to remember the size of previous data to preallocate the next.
        """
    def serialize_simple(self, data: list[int]) -> bool:
        """
        Same as :meth:`Gst.Meta.serialize` but with a :class:`GByteArray` instead of
        :class:`Gst.ByteArrayInterface`.
        """
    @staticmethod
    def api_type_aggregate_params(api: type | GObject.Type, aggregated_params: Structure, params0: Structure, params1: Structure) -> bool:
        """
        When a element like ``tee`` decides the allocation, each downstream element may
        fill different parameters and pass them to :meth:`Gst.Query.add_allocation_meta`.
        In order to keep these parameters, a merge operation is needed. This
        aggregate function can combine the parameters from ``params0`` and ``param1``, and
        write the result back into ``aggregated_params``.
        """
    @staticmethod
    def api_type_get_tags(api: type | GObject.Type) -> list[str]: ...
    @staticmethod
    def api_type_has_tag(api: type | GObject.Type, tag: GLib.Quark) -> bool:
        """
        Check if ``api`` was registered with ``tag``.
        """
    @staticmethod
    def api_type_register(api: str, tags: list[str]) -> type | GObject.Type:
        """
        Register and return a GType for the ``api`` and associate it with
        ``tags``.
        """
    @staticmethod
    def api_type_set_params_aggregator(api: type | GObject.Type, aggregator: AllocationMetaParamsAggregator) -> None:
        """
        This function sets the aggregator function for a specific API type.
        """
    @staticmethod
    def api_type_tags_contain_only(api: type | GObject.Type, valid_tags: list[str]) -> bool: ...
    @staticmethod
    def deserialize(buffer: Buffer, data: list[int]) -> tuple[Meta | None, int]:
        """
        Recreate a :class:`Gst.Meta` from serialized data returned by
        :meth:`Gst.Meta.serialize` and add it to ``buffer``.

        Note that the meta must have been previously registered by calling one of
        ``gst_*_meta_get_info ()`` functions.

        ``consumed`` is set to the number of bytes that can be skipped from ``data`` to
        find the next meta serialization, if any. In case of parsing error that does
        not allow to determine that size, ``consumed`` is set to 0.
        """
    @staticmethod
    def get_info(impl: str) -> MetaInfo | None:
        """
        Lookup a previously registered meta info structure by its implementation name
        ``impl``.
        """
    @staticmethod
    def register_custom(name: str, tags: list[str], transform_func: CustomMetaTransformFunction | None = ...) -> MetaInfo:
        """
        Register a new custom :class:`Gst.Meta` implementation, backed by an opaque
        structure holding a :class:`Gst.Structure`.

        The registered info can be retrieved later with :func:`Gst.meta_get_info` by using
        ``name`` as the key.

        The backing :class:`Gst.Structure` can be retrieved with
        :meth:`Gst.CustomMeta.get_structure`, its mutability is conditioned by the
        writability of the buffer the meta is attached to.

        When ``transform_func`` is ``None``, the meta and its backing :class:`Gst.Structure`
        will always be copied when the transform operation is copy, other operations
        are discarded, copy regions are ignored.
        """
    @staticmethod
    def register_custom_simple(name: str) -> MetaInfo:
        """
        Simplified version of :func:`Gst.meta_register_custom`, with no tags and no
        transform function.
        """

class MetaFactory(PluginFeature):
    """
    Register a :class:`Gst.MetaInfo` that can be automatically loaded the first time it is
    used.

    In general, applications and plugins don't need to use the factory
    beyond registering the meta in a plugin init function. Once that is
