class TimedAnimation(Animation):
    """
    A time-based :class:`Animation`.

    :class:`Adw.TimedAnimation` implements a simple animation interpolating the given
    value from :attr:`TimedAnimation.value-from` to
    :attr:`TimedAnimation.value-to` over
    :attr:`TimedAnimation.duration` milliseconds using the curve described by
    :attr:`TimedAnimation.easing`.

    If :attr:`TimedAnimation.reverse` is set to ``True``, :class:`Adw.TimedAnimation`
    will instead animate from :attr:`TimedAnimation.value-to` to
    :attr:`TimedAnimation.value-from`, and the easing curve will be inverted.

    The animation can repeat a certain amount of times, or endlessly, depending
    on the :attr:`TimedAnimation.repeat-count` value. If
    :attr:`TimedAnimation.alternate` is set to ``True``, it will also change the
    direction every other iteration.
    """
    gimeta: ClassVar[_GIMeta]
    alternate: bool
    duration: int
    easing: Easing | int
    repeat_count: int
    reverse: bool
